<Window x:Class="FluxRoute.Views.UpdateCheckDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Проверка обновлений"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight">
    <Window.Resources>
        <!-- Кнопки модального окна не используют яркий системный hover WPF. -->
        <Style x:Key="UpdateDialogSecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="#9AA8BF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#273247" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="15,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BackgroundBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="#182235" />
                                <Setter Property="Foreground" Value="#DCE4F0" />
                                <Setter Property="BorderBrush" Value="#35445F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="#101827" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UpdateDialogPrimaryButton"
               TargetType="Button"
               BasedOn="{StaticResource UpdateDialogSecondaryButton}">
            <Setter Property="Foreground" Value="#DCE4F0" />
            <Setter Property="Background" Value="#26355F" />
            <Setter Property="BorderBrush" Value="#4D6BFE" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BackgroundBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="#155E75" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderBrush" Value="#2188A6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="#0E4F63" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#0C0F17"
            BorderBrush="#24443D"
            BorderThickness="1"
            CornerRadius="14"
            MinWidth="390"
            MaxWidth="480"
            MouseLeftButtonDown="Root_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="28" ShadowDepth="8" Opacity="0.55" />
        </Border.Effect>
        <Grid Margin="22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="34" Height="34" CornerRadius="17"
                        Background="#132B28" BorderBrush="#245249" BorderThickness="1">
                    <TextBlock x:Name="StatusIcon" Text="↻" FontSize="18" Foreground="#5BD6C1"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock x:Name="TitleText" Text="Проверка обновлений"
                               Foreground="#DCE4F0" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock x:Name="ComponentText" Foreground="#7E89A8" FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
            </Grid>

            <TextBlock x:Name="MessageText" Grid.Row="1"
                       Foreground="#A9B6CC" FontSize="12" TextWrapping="Wrap"
                       Margin="0,0,0,12" />

            <Border Grid.Row="2" Background="#101620" BorderBrush="#1C2636"
                    BorderThickness="1" CornerRadius="9" Padding="12,10" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Установленная версия" Foreground="#66738A" FontSize="10" />
                        <TextBlock x:Name="CurrentVersionText" Text="—" Foreground="#DCE4F0"
                                   FontFamily="Consolas" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="#263142" Margin="0,0" />
                    <StackPanel Grid.Column="2" Margin="12,0,0,0">
                        <TextBlock Text="Последняя версия" Foreground="#66738A" FontSize="10" />
                        <TextBlock x:Name="LatestVersionText" Text="—" Foreground="#5BD6C1"
                                   FontFamily="Consolas" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="3">
                <ProgressBar x:Name="ProgressIndicator" Height="3" IsIndeterminate="True"
                             Foreground="#4D6BFE" Background="#1C2636" VerticalAlignment="Center" />
                <StackPanel x:Name="ButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Right"
                            Visibility="Collapsed">
                    <Button x:Name="SecondaryButton" Content="Закрыть" Margin="0,0,8,0"
                            Style="{StaticResource UpdateDialogSecondaryButton}"
                            Click="Secondary_Click" />
                    <Button x:Name="PrimaryButton" Content="Обновить"
                            Style="{StaticResource UpdateDialogPrimaryButton}"
                            Click="Primary_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
