<Window x:Class="FluxRoute.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О проекте FluxRoute"
        Height="560" Width="620"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="#0C0F17" BorderBrush="#1C1F2E" BorderThickness="1" CornerRadius="12">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0C0F17" CornerRadius="12,12,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid Margin="16,0">
                <TextBlock Text="О проекте FluxRoute" FontSize="16" FontWeight="SemiBold"
                           Foreground="#C8D4EC" VerticalAlignment="Center"/>
                <Button Width="34" Height="34" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="CloseButton_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                               Foreground="#4A5170" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16">
                <TextBlock Text="Для чего создан проект" Foreground="#4A90E2" FontWeight="SemiBold" FontSize="14"/>
                <TextBlock Margin="0,8,0,0" Foreground="#C8D4EC" TextWrapping="Wrap" FontSize="13"
                           Text="FluxRoute создан как удобный desktop-интерфейс для управления сетевыми профилями и сценариями обхода ограничений. Главная цель — упростить запуск и переключение стратегий без ручного редактирования bat-файлов и служебных настроек."/>

                <Rectangle Height="1" Fill="#3E3E42" Margin="0,14,0,14"/>

                <TextBlock Text="Как работает" Foreground="#4FC3F7" FontWeight="SemiBold" FontSize="14"/>
                <TextBlock Margin="0,8,0,0" Foreground="#DDDDDD" TextWrapping="Wrap" FontSize="13"
                           Text="Приложение загружает профили из каталога engine, запускает выбранный сценарий, отслеживает статус процесса и базовую диагностику. Внутри есть оркестратор, который анализирует доступность выбранных целей и помогает переключать профиль на более стабильный."/>

                <Rectangle Height="1" Fill="#3E3E42" Margin="0,14,0,14"/>

                <TextBlock Text="Основа engine" Foreground="#4FC3F7" FontWeight="SemiBold" FontSize="14"/>
                <TextBlock Margin="0,8,0,0" Foreground="#DDDDDD" TextWrapping="Wrap" FontSize="13"
                           Text="FluxRoute использует экосистему проектов в такой цепочке:"/>

                <StackPanel Margin="12,10,0,0">
                    <TextBlock Foreground="#DDDDDD" FontSize="13" Margin="0,4">
                        <Run Text="• "/><Hyperlink NavigateUri="https://github.com/basil00/WinDivert" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7">WinDivert</Hyperlink> — <Run Text="низкоуровневая основа для Windows"/>
                    </TextBlock>
                    <TextBlock Foreground="#DDDDDD" FontSize="13" Margin="0,4">
                        <Run Text="• "/><Hyperlink NavigateUri="https://github.com/bol-van/zapret" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7">bol-van/zapret</Hyperlink> — <Run Text="оригинальный проект"/>
                    </TextBlock>
                    <TextBlock Foreground="#DDDDDD" FontSize="13" Margin="0,4">
                        <Run Text="• "/><Hyperlink NavigateUri="https://github.com/bol-van/zapret-win-bundle" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7">bol-van/zapret-win-bundle</Hyperlink> — <Run Text="Windows-бандл с winws.exe"/>
                    </TextBlock>
                    <TextBlock Foreground="#DDDDDD" FontSize="13" Margin="0,4">
                        <Run Text="• "/><Hyperlink NavigateUri="https://github.com/Flowseal/zapret-discord-youtube" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7">Flowseal/zapret-discord-youtube</Hyperlink> — <Run Text="непосредственная основа engine"/>
                    </TextBlock>
                </StackPanel>

                <Rectangle Height="1" Fill="#3E3E42" Margin="0,14,0,14"/>

                <TextBlock Text="Вдохновение" Foreground="#4FC3F7" FontWeight="SemiBold" FontSize="14"/>

                <StackPanel Margin="12,10,0,0">
                    <TextBlock Foreground="#DDDDDD" FontSize="13" Margin="0,4">
                        <Run Text="• "/><Hyperlink NavigateUri="https://github.com/medvedeff-true/Zapret-GUI" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7">medvedeff-true/Zapret-GUI</Hyperlink>
                    </TextBlock>
                    <TextBlock Foreground="#DDDDDD" FontSize="13" Margin="0,4">
                        <Run Text="• "/><Hyperlink NavigateUri="https://github.com/Virenbar/ZapretControl" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7">Virenbar/ZapretControl</Hyperlink>
                    </TextBlock>
                    <TextBlock Foreground="#DDDDDD" FontSize="13" Margin="0,4">
                        <Run Text="• "/><Hyperlink NavigateUri="https://github.com/youtubediscord/zapret" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7">youtubediscord/zapret</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
    </Border>
</Window>
