<Window x:Class="FluxRoute.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:conv="clr-namespace:FluxRoute.Converters"
		mc:Ignorable="d"
        Title="FluxRoute"
        Height="530" Width="760"
        WindowStartupLocation="CenterScreen"
		Background="#0D1117"
		WindowStyle="None"
		ResizeMode="NoResize">

	<WindowChrome.WindowChrome>
		<WindowChrome CaptionHeight="0"
					  ResizeBorderThickness="0"
					  GlassFrameThickness="0"/>
	</WindowChrome.WindowChrome>

	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVis"/>
		<conv:InverseBooleanConverter x:Key="InvBool"/>

		<!-- ══════ TERMINAL BUTTON ══════ -->
		<Style x:Key="TermBtn" TargetType="Button">
			<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
			<Setter Property="FontFamily" Value="Segoe UI"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Foreground" Value="#8B949E"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush" Value="#30363D"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Padding" Value="14,6"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}">
							<Grid>
								<Border Background="{TemplateBinding Background}"/>
								<Border x:Name="HoverOverlay" Opacity="0">
									<Border.Background>
										<SolidColorBrush Color="#1C2128"/>
									</Border.Background>
								</Border>
								<ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
							</Grid>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Foreground" Value="#E6EDF3"/>
								<Setter TargetName="Bd" Property="BorderBrush" Value="#4FC3F7"/>
								<Trigger.EnterActions>
									<BeginStoryboard>
										<Storyboard>
											<DoubleAnimation Storyboard.TargetName="HoverOverlay"
												Storyboard.TargetProperty="Opacity"
												To="1" Duration="0:0:0.15">
												<DoubleAnimation.EasingFunction>
													<CubicEase EasingMode="EaseOut"/>
												</DoubleAnimation.EasingFunction>
											</DoubleAnimation>
										</Storyboard>
									</BeginStoryboard>
								</Trigger.EnterActions>
								<Trigger.ExitActions>
									<BeginStoryboard>
										<Storyboard>
											<DoubleAnimation Storyboard.TargetName="HoverOverlay"
												Storyboard.TargetProperty="Opacity"
												To="0" Duration="0:0:0.2">
												<DoubleAnimation.EasingFunction>
													<CubicEase EasingMode="EaseOut"/>
												</DoubleAnimation.EasingFunction>
											</DoubleAnimation>
										</Storyboard>
									</BeginStoryboard>
								</Trigger.ExitActions>
							</Trigger>
							<Trigger Property="IsEnabled" Value="False">
								<Setter Property="Opacity" Value="0.4"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ══════ ACCENT BUTTON ══════ -->
		<Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource TermBtn}">
			<Setter Property="Foreground" Value="#4FC3F7"/>
			<Setter Property="BorderBrush" Value="#264F78"/>
		</Style>

		<!-- ══════ GREEN BUTTON ══════ -->
		<Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource TermBtn}">
			<Setter Property="Foreground" Value="#3FB950"/>
			<Setter Property="BorderBrush" Value="#238636"/>
		</Style>

		<!-- ══════ RED BUTTON ══════ -->
		<Style x:Key="RedBtn" TargetType="Button" BasedOn="{StaticResource TermBtn}">
			<Setter Property="Foreground" Value="#F85149"/>
			<Setter Property="BorderBrush" Value="#DA3633"/>
		</Style>

		<!-- ══════ NAV BUTTON ══════ -->
		<Style x:Key="NavBtn" TargetType="Button">
			<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
			<Setter Property="FontFamily" Value="Segoe UI"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Foreground" Value="#8B949E"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="3,0,0,0"/>
			<Setter Property="HorizontalContentAlignment" Value="Left"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Padding" Value="10,8"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
							<Grid>
								<Border Background="{TemplateBinding Background}"/>
								<Border x:Name="HoverOverlay" Opacity="0">
									<Border.Background>
										<SolidColorBrush Color="#161B22"/>
									</Border.Background>
								</Border>
								<ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Left" VerticalAlignment="Center"/>
							</Grid>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Foreground" Value="#E6EDF3"/>
								<Trigger.EnterActions>
									<BeginStoryboard>
										<Storyboard>
											<DoubleAnimation Storyboard.TargetName="HoverOverlay"
															 Storyboard.TargetProperty="Opacity"
															 To="1" Duration="0:0:0.15">
										<DoubleAnimation.EasingFunction>
											<CubicEase EasingMode="EaseOut"/>
										</DoubleAnimation.EasingFunction>
									</DoubleAnimation>
								</Storyboard>
									</BeginStoryboard>
								</Trigger.EnterActions>
								<Trigger.ExitActions>
									<BeginStoryboard>
										<Storyboard>
											<DoubleAnimation Storyboard.TargetName="HoverOverlay"
															 Storyboard.TargetProperty="Opacity"
															 To="0" Duration="0:0:0.2">
										<DoubleAnimation.EasingFunction>
											<CubicEase EasingMode="EaseOut"/>
										</DoubleAnimation.EasingFunction>
									</DoubleAnimation>
								</Storyboard>
									</BeginStoryboard>
								</Trigger.ExitActions>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ══════ SECTION HEADER ══════ -->
		<Style x:Key="SecH" TargetType="TextBlock">
			<Setter Property="FontFamily" Value="Segoe UI"/>
			<Setter Property="Foreground" Value="#4FC3F7"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Margin" Value="0,14,0,8"/>
		</Style>

		<!-- ══════ LABEL ══════ -->
		<Style x:Key="Lbl" TargetType="TextBlock">
			<Setter Property="FontFamily" Value="Segoe UI"/>
			<Setter Property="Foreground" Value="#8B949E"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
		</Style>

		<!-- ══════ VALUE ══════ -->
		<Style x:Key="Val" TargetType="TextBlock">
			<Setter Property="FontFamily" Value="Segoe UI"/>
			<Setter Property="Foreground" Value="#E6EDF3"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
		</Style>

		<!-- ══════ CARD ══════ -->
		<Style x:Key="Card" TargetType="Border">
			<Setter Property="Background" Value="#161B22"/>
			<Setter Property="BorderBrush" Value="#30363D"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="12,10"/>
		</Style>

		<!-- ══════ LOG AREA ══════ -->
		<Style x:Key="LogArea" TargetType="Border">
			<Setter Property="Background" Value="#0D1117"/>
			<Setter Property="BorderBrush" Value="#21262D"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="8"/>
			<Setter Property="MaxHeight" Value="150"/>
		</Style>

		<!-- ══════ COMBOBOX ══════ -->
		<Style TargetType="ComboBox">
			<Setter Property="Background" Value="#161B22"/>
			<Setter Property="Foreground" Value="#E6EDF3"/>
			<Setter Property="BorderBrush" Value="#30363D"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="FontFamily" Value="Segoe UI"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Height" Value="28"/>
			<Setter Property="Padding" Value="6,3"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ComboBox">
						<Grid>
							<Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="24"/>
									</Grid.ColumnDefinitions>
									<ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="6,0,0,0" VerticalAlignment="Center">
										<ContentPresenter.Resources>
											<Style TargetType="TextBlock">
												<Setter Property="Foreground" Value="#E6EDF3"/>
												<Setter Property="FontFamily" Value="Segoe UI"/>
												<Setter Property="FontSize" Value="12"/>
											</Style>
										</ContentPresenter.Resources>
									</ContentPresenter>
									<TextBlock Grid.Column="1" Text="▾" Foreground="#8B949E"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="11" FontFamily="Segoe UI"/>
									<ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent" BorderThickness="0"
                                                  Cursor="Hand" Opacity="0"/>
								</Grid>
							</Border>
							<Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" PopupAnimation="Slide">
								<Border Background="#161B22" BorderBrush="#30363D"
                                        BorderThickness="1" Margin="0,2,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
									<ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
										<ItemsPresenter/>
									</ScrollViewer>
								</Border>
							</Popup>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		<Style TargetType="ComboBoxItem">
			<Setter Property="Background" Value="#161B22"/>
			<Setter Property="Foreground" Value="#E6EDF3"/>
			<Setter Property="FontFamily" Value="Segoe UI"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Padding" Value="8,5"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ComboBoxItem">
						<Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#1C2128"/>
							</Trigger>
							<Trigger Property="IsSelected" Value="True">
								<Setter Property="Background" Value="#264F78"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ══════ CHECKBOX ══════ -->
		<Style TargetType="CheckBox">
			<Setter Property="Foreground" Value="#8B949E"/>
			<Setter Property="FontFamily" Value="Segoe UI"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Margin" Value="0,4"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>

		<!-- ══════ SEPARATOR ══════ -->
		<Style x:Key="Sep" TargetType="Rectangle">
			<Setter Property="Height" Value="1"/>
			<Setter Property="Fill" Value="#21262D"/>
			<Setter Property="Margin" Value="0,8"/>
		</Style>

		<!-- ══════ TEXTBOX ══════ -->
		<Style TargetType="TextBox">
			<Setter Property="Background" Value="#161B22"/>
			<Setter Property="Foreground" Value="#E6EDF3"/>
			<Setter Property="BorderBrush" Value="#30363D"/>
			<Setter Property="FontFamily" Value="Segoe UI"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Padding" Value="6,4"/>
			<Setter Property="CaretBrush" Value="#E6EDF3"/>
		</Style>
	</Window.Resources>

	<Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="36"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="26"/>
			</Grid.RowDefinitions>

			<!-- ═══════════ TITLE BAR ═══════════ -->
			<Border Grid.Row="0" Background="#010409" CornerRadius="4,4,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
				<Grid Margin="14,0">
					<TextBlock Text="FluxRoute" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                               Foreground="#E6EDF3" VerticalAlignment="Center"/>
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,-6,0">
						<Button Width="36" Height="36" Click="MinimizeButton_Click">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border x:Name="Bd" Background="Transparent">
										<Grid>
											<Border x:Name="HoverOverlay" Opacity="0">
												<Border.Background>
													<SolidColorBrush Color="#1C2128"/>
												</Border.Background>
											</Border>
											<TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"
												Foreground="#8B949E" x:Name="Ico"
												HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Grid>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter TargetName="Ico" Property="Foreground" Value="#E6EDF3"/>
											<Trigger.EnterActions>
												<BeginStoryboard>
													<Storyboard>
														<DoubleAnimation Storyboard.TargetName="HoverOverlay"
															Storyboard.TargetProperty="Opacity"
															To="1" Duration="0:0:0.15">
															<DoubleAnimation.EasingFunction>
																<CubicEase EasingMode="EaseOut"/>
															</DoubleAnimation.EasingFunction>
														</DoubleAnimation>
													</Storyboard>
												</BeginStoryboard>
											</Trigger.EnterActions>
											<Trigger.ExitActions>
												<BeginStoryboard>
													<Storyboard>
														<DoubleAnimation Storyboard.TargetName="HoverOverlay"
															Storyboard.TargetProperty="Opacity"
															To="0" Duration="0:0:0.2">
															<DoubleAnimation.EasingFunction>
																<CubicEase EasingMode="EaseOut"/>
															</DoubleAnimation.EasingFunction>
														</DoubleAnimation>
													</Storyboard>
												</BeginStoryboard>
											</Trigger.ExitActions>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Button.Template>
						</Button>
						<Button Width="36" Height="36" Click="CloseButton_Click">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border x:Name="Bd" Background="Transparent">
										<Grid>
											<Border x:Name="HoverOverlay" Opacity="0">
												<Border.Background>
													<SolidColorBrush Color="#DA3633"/>
												</Border.Background>
											</Border>
											<TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
												Foreground="#8B949E" x:Name="Ico"
												HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Grid>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter TargetName="Ico" Property="Foreground" Value="#E6EDF3"/>
											<Trigger.EnterActions>
												<BeginStoryboard>
													<Storyboard>
														<DoubleAnimation Storyboard.TargetName="HoverOverlay"
															Storyboard.TargetProperty="Opacity"
															To="1" Duration="0:0:0.15">
															<DoubleAnimation.EasingFunction>
																<CubicEase EasingMode="EaseOut"/>
															</DoubleAnimation.EasingFunction>
														</DoubleAnimation>
													</Storyboard>
												</BeginStoryboard>
											</Trigger.EnterActions>
											<Trigger.ExitActions>
												<BeginStoryboard>
													<Storyboard>
														<DoubleAnimation Storyboard.TargetName="HoverOverlay"
															Storyboard.TargetProperty="Opacity"
															To="0" Duration="0:0:0.2">
															<DoubleAnimation.EasingFunction>
																<CubicEase EasingMode="EaseOut"/>
															</DoubleAnimation.EasingFunction>
														</DoubleAnimation>
													</Storyboard>
												</BeginStoryboard>
											</Trigger.ExitActions>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Button.Template>
						</Button>
					</StackPanel>
				</Grid>
			</Border>

			<!-- ═══════════ BODY ═══════════ -->
			<Grid Grid.Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<!-- ─── SIDEBAR ─── -->
				<Border Grid.Column="0" Background="#0D1117" x:Name="SidebarBorder" Width="165" ClipToBounds="True">
					<StackPanel>
						<Button Height="36" Command="{Binding ToggleSidebarCommand}" Cursor="Hand">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border x:Name="Bd" Background="Transparent" BorderThickness="3,0,0,0" BorderBrush="Transparent">
										<Grid>
											<Border x:Name="HoverOverlay" Opacity="0">
												<Border.Background>
													<SolidColorBrush Color="#161B22"/>
												</Border.Background>
											</Border>
											<TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="14"
												Foreground="#8B949E" x:Name="Ico" Margin="10,8"
												Width="20" TextAlignment="Center"
												HorizontalAlignment="Left" VerticalAlignment="Center"/>
										</Grid>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter TargetName="Ico" Property="Foreground" Value="#E6EDF3"/>
											<Trigger.EnterActions>
												<BeginStoryboard>
													<Storyboard>
														<DoubleAnimation Storyboard.TargetName="HoverOverlay"
															Storyboard.TargetProperty="Opacity"
															To="1" Duration="0:0:0.15">
															<DoubleAnimation.EasingFunction>
																<CubicEase EasingMode="EaseOut"/>
															</DoubleAnimation.EasingFunction>
														</DoubleAnimation>
													</Storyboard>
												</BeginStoryboard>
											</Trigger.EnterActions>
											<Trigger.ExitActions>
												<BeginStoryboard>
													<Storyboard>
														<DoubleAnimation Storyboard.TargetName="HoverOverlay"
															Storyboard.TargetProperty="Opacity"
															To="0" Duration="0:0:0.2">
															<DoubleAnimation.EasingFunction>
																<CubicEase EasingMode="EaseOut"/>
															</DoubleAnimation.EasingFunction>
														</DoubleAnimation>
													</Storyboard>
												</BeginStoryboard>
											</Trigger.ExitActions>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Button.Template>
						</Button>

						<Grid>
							<StackPanel>
								<!-- Nav: Главная -->
								<Button Height="36" Command="{Binding SelectTabCommand}" CommandParameter="0">
									<Button.Style>
										<Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
											<Style.Triggers>
												<DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
													<Setter Property="Foreground" Value="#E6EDF3"/>
													<Setter Property="Background" Value="#161B22"/>
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</Button.Style>
									<StackPanel Orientation="Horizontal">
																				<TextBlock Text="🏠" Width="20" TextAlignment="Center"/>
																				<TextBlock Text="Главная" Margin="6,0,0,0" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}"/>
																			</StackPanel>
								</Button>

								<!-- Nav: TG Прокси -->
								<Button Height="36" Command="{Binding SelectTabCommand}" CommandParameter="1">
									<Button.Style>
										<Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
											<Style.Triggers>
												<DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
													<Setter Property="Foreground" Value="#E6EDF3"/>
													<Setter Property="Background" Value="#161B22"/>
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</Button.Style>
									<StackPanel Orientation="Horizontal">
										<TextBlock Text="✈" Width="20" TextAlignment="Center"/>
										<TextBlock Text="TG Прокси" Margin="6,0,0,0" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}"/>
									</StackPanel>
								</Button>

								<!-- Nav: Оркестратор -->
								<Button Height="36" Command="{Binding SelectTabCommand}" CommandParameter="2">
										<Button.Style>
											<Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
												<Style.Triggers>
													<DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
														<Setter Property="Foreground" Value="#E6EDF3"/>
														<Setter Property="Background" Value="#161B22"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</Button.Style>
										<StackPanel Orientation="Horizontal">
																		<TextBlock Text="⚙" Width="20" TextAlignment="Center"/>
																		<TextBlock Text="Оркестратор" Margin="6,0,0,0" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}"/>
																	</StackPanel>
									</Button>

									<!-- Nav: Обновление -->
									<Button Height="36" Command="{Binding SelectTabCommand}" CommandParameter="3">
										<Button.Style>
											<Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
												<Style.Triggers>
													<DataTrigger Binding="{Binding SelectedTabIndex}" Value="3">
														<Setter Property="Foreground" Value="#E6EDF3"/>
														<Setter Property="Background" Value="#161B22"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</Button.Style>
										<StackPanel Orientation="Horizontal">
																		<TextBlock Text="🔄" Width="20" TextAlignment="Center"/>
																		<TextBlock Text="Обновление" Margin="6,0,0,0" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}"/>
																	</StackPanel>
									</Button>

									<!-- Nav: Диагностика -->
									<Button Height="36" Command="{Binding SelectTabCommand}" CommandParameter="4">
										<Button.Style>
											<Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
												<Style.Triggers>
													<DataTrigger Binding="{Binding SelectedTabIndex}" Value="4">
														<Setter Property="Foreground" Value="#E6EDF3"/>
														<Setter Property="Background" Value="#161B22"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</Button.Style>
										<StackPanel Orientation="Horizontal">
																		<TextBlock Text="🔧" Width="20" TextAlignment="Center"/>
																		<TextBlock Text="Диагностика" Margin="6,0,0,0" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}"/>
																	</StackPanel>
									</Button>

									<!-- Nav: Сервис -->
									<Button Height="36" Command="{Binding SelectTabCommand}" CommandParameter="5">
										<Button.Style>
											<Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
												<Style.Triggers>
													<DataTrigger Binding="{Binding SelectedTabIndex}" Value="5">
														<Setter Property="Foreground" Value="#E6EDF3"/>
														<Setter Property="Background" Value="#161B22"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</Button.Style>
										<StackPanel Orientation="Horizontal">
																		<TextBlock Text="🛠" Width="20" TextAlignment="Center"/>
																		<TextBlock Text="Сервис" Margin="6,0,0,0" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}"/>
																	</StackPanel>
									</Button>

									<!-- Nav: О программе -->
									<Button Height="36" Command="{Binding SelectTabCommand}" CommandParameter="6">
										<Button.Style>
											<Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
												<Style.Triggers>
													<DataTrigger Binding="{Binding SelectedTabIndex}" Value="6">
														<Setter Property="Foreground" Value="#E6EDF3"/>
														<Setter Property="Background" Value="#161B22"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</Button.Style>
										<StackPanel Orientation="Horizontal">
																		<TextBlock Text="ℹ" Width="20" TextAlignment="Center"/>
																		<TextBlock Text="О программе" Margin="6,0,0,0" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}"/>
																	</StackPanel>
									</Button>

							</StackPanel>

							<!-- Sliding accent indicator -->
							<Border Width="3" Height="36" HorizontalAlignment="Left" VerticalAlignment="Top"
                                    IsHitTestVisible="False">
								<Border.Background>
									<SolidColorBrush Color="#4FC3F7"/>
								</Border.Background>
								<Border.RenderTransform>
									<TranslateTransform x:Name="NavIndicatorTransform"/>
								</Border.RenderTransform>
							</Border>
						</Grid>
					</StackPanel>
				</Border>

				<!-- ─── VERTICAL SEPARATOR ─── -->
				<Rectangle Grid.Column="1" Width="1" Fill="#30363D"/>

				<!-- ─── CONTENT AREA ─── -->
				<Grid Grid.Column="2">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<!-- Page Title -->
					<Border Grid.Row="0" BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="16,8">
						<TextBlock Text="{Binding SelectedTabName}" FontFamily="Segoe UI" FontSize="15"
                                   FontWeight="Bold" Foreground="#E6EDF3"/>
					</Border>

					<!-- ═══ PAGES ═══ -->
					<Grid Grid.Row="1">

						<!-- ╔══════════════════════════════════════╗ -->
						<!-- ║          TAB 0: ГЛАВНАЯ             ║ -->
						<!-- ╚══════════════════════════════════════╝ -->
						<Border
                                d:Visibility="Visible" d:Opacity="1">
							<Border.Style>
								<Style TargetType="Border">
									<Setter Property="Visibility" Value="Collapsed"/>
									<Setter Property="Opacity" Value="0"/>
									<Style.Triggers>
										<DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
											<Setter Property="Visibility" Value="Visible"/>
											<DataTrigger.EnterActions>
												<BeginStoryboard>
													<Storyboard>
														<DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="0" To="1" Duration="0:0:0.3">
															<DoubleAnimation.EasingFunction>
																<CubicEase EasingMode="EaseOut"/>
															</DoubleAnimation.EasingFunction>
														</DoubleAnimation>
													</Storyboard>
												</BeginStoryboard>
											</DataTrigger.EnterActions>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</Border.Style>
							<ScrollViewer VerticalScrollBarVisibility="Auto">
								<StackPanel Margin="16,12">

									<!-- Engine download banner -->
									<Border Background="#1C1500" BorderBrush="#5A4800" BorderThickness="1"
                                            Padding="10,8" Margin="0,0,0,12"
                                            Visibility="{Binding IsDownloadingEngine, Converter={StaticResource BoolToVis}}">
										<StackPanel>
											<TextBlock Text="⬇️ Первый запуск — скачиваем Flowseal..." FontFamily="Segoe UI"
                                                       Foreground="#FFD700" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
											<TextBlock Text="{Binding EngineDownloadStatus}" FontFamily="Segoe UI"
                                                       Foreground="#CCAA00" FontSize="11" TextWrapping="Wrap"/>
										</StackPanel>
									</Border>

									<!-- STATUS + PROFILE row -->
									<Grid Margin="0,0,0,12">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="12"/>
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>

										<!-- Status card -->
										<Border Grid.Column="0" Style="{StaticResource Card}">
											<StackPanel>
												<TextBlock Text="Статус" FontFamily="Segoe UI" Foreground="#4FC3F7"
                                                           FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
												<StackPanel Orientation="Horizontal" Margin="0,0,0,4">
													<TextBlock FontFamily="Segoe UI" FontSize="13" Margin="0,0,6,0">
														<TextBlock.Style>
															<Style TargetType="TextBlock">
																<Setter Property="Text" Value="○"/>
																<Setter Property="Foreground" Value="#F85149"/>
																<Style.Triggers>
																	<DataTrigger Binding="{Binding IsRunning}" Value="True">
																		<Setter Property="Text" Value="●"/>
																		<Setter Property="Foreground" Value="#3FB950"/>
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</TextBlock.Style>
													</TextBlock>
													<TextBlock FontFamily="Segoe UI" FontSize="13">
														<TextBlock.Style>
															<Style TargetType="TextBlock">
																<Setter Property="Text" Value="Защита не активна"/>
																<Setter Property="Foreground" Value="#F85149"/>
																<Style.Triggers>
																	<DataTrigger Binding="{Binding IsRunning}" Value="True">
																		<Setter Property="Text" Value="Защита активна"/>
																		<Setter Property="Foreground" Value="#3FB950"/>
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</TextBlock.Style>
													</TextBlock>
												</StackPanel>
												<TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#8B949E" Margin="0,2,0,0">
                                                    <Run Text="PID: "/><Run Text="{Binding PidText, Mode=OneWay}" Foreground="#E6EDF3"/>
												</TextBlock>
												<TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#8B949E">
                                                    <Run Text="Uptime: "/><Run Text="{Binding UptimeText, Mode=OneWay}" Foreground="#E6EDF3"/>
												</TextBlock>
											</StackPanel>
										</Border>

										<!-- Profile card -->
										<Border Grid.Column="2" Style="{StaticResource Card}">
											<StackPanel>
												<TextBlock Text="Профиль" FontFamily="Segoe UI" Foreground="#4FC3F7"
                                                           FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
												<ComboBox ItemsSource="{Binding Profiles}"
                                                          SelectedItem="{Binding SelectedProfile}"
                                                          Margin="0,0,0,8">
													<ComboBox.ItemTemplate>
														<DataTemplate>
															<TextBlock Text="{Binding DisplayName}" FontFamily="Segoe UI"
                                                                       Foreground="#E6EDF3" FontSize="12"/>
														</DataTemplate>
													</ComboBox.ItemTemplate>
												</ComboBox>
												<Button Content="Обновить список" Style="{StaticResource TermBtn}"
                                                        FontSize="11" Padding="8,4"
                                                        Command="{Binding RefreshProfilesCommand}"
                                                        HorizontalAlignment="Left"/>
											</StackPanel>
										</Border>
									</Grid>

									<!-- ACTION BUTTON -->
									<Border Style="{StaticResource Card}" Margin="0,0,0,12">
										<Button Command="{Binding ToggleStartStopCommand}"
                                                Content="{Binding MainActionButtonText}"
                                                FontSize="14" Padding="28,8"
                                                HorizontalAlignment="Center">
											<Button.Style>
												<Style TargetType="Button" BasedOn="{StaticResource GreenBtn}">
													<Style.Triggers>
														<DataTrigger Binding="{Binding IsRunning}" Value="True">
															<Setter Property="Foreground" Value="#F85149"/>
															<Setter Property="BorderBrush" Value="#DA3633"/>
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</Button.Style>
										</Button>
									</Border>

									<!-- DIAGNOSTICS + QUICK ACTIONS row -->
									<Grid Margin="0,0,0,12">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="12"/>
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>

										<!-- Diagnostics card -->
										<Border Grid.Column="0" Style="{StaticResource Card}">
											<StackPanel>
												<TextBlock Text="Диагностика" FontFamily="Segoe UI" Foreground="#4FC3F7"
                                                           FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
												<TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#8B949E" Margin="0,2,0,0">
                                                    <Run Text="winws.exe: "/><Run Text="{Binding WinwsText, Mode=OneWay}" Foreground="#E6EDF3"/>
												</TextBlock>
												<TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#8B949E" Margin="0,2,0,0">
                                                    <Run Text="Engine: "/><Run Text="{Binding CurrentEngineVersion, Mode=OneWay}" Foreground="#E6EDF3"/>
												</TextBlock>
												<TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#8B949E" Margin="0,2,0,0">
                                                    <Run Text="Администратор: "/><Run Text="{Binding AdminText, Mode=OneWay}" Foreground="#E6EDF3"/>
												</TextBlock>
											</StackPanel>
										</Border>

										<!-- Quick Actions card -->
										<Border Grid.Column="2" Style="{StaticResource Card}">
											<StackPanel>
												<TextBlock Text="Быстрые действия" FontFamily="Segoe UI" Foreground="#4FC3F7"
                                                           FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
												<Button Content="Открыть папку" Style="{StaticResource TermBtn}"
                                                        FontSize="12" Padding="8,4"
                                                        Command="{Binding OpenEngineFolderCommand}"
                                                        HorizontalAlignment="Left" Margin="0,0,0,4"/>
												<Button Content="Показать логи" Style="{StaticResource TermBtn}"
                                                        FontSize="12" Padding="8,4"
                                                        Command="{Binding ShowLogsCommand}"
                                                        HorizontalAlignment="Left" Margin="0,0,0,4"/>
												<Button Content="Проверить сейчас" Style="{StaticResource TermBtn}"
                                                        FontSize="12" Padding="8,4"
                                                        Command="{Binding CheckNowCommand}"
                                                        HorizontalAlignment="Left"/>
											</StackPanel>
										</Border>
									</Grid>

									<!-- Status line -->
									<Border BorderBrush="#21262D" BorderThickness="0,1,0,0" Padding="0,8,0,0">
										<TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#8B949E" TextWrapping="Wrap">
                                            <Run Text="Строка состояния: "/><Run Text="{Binding LastStatusMessage, Mode=OneWay}" Foreground="#E6EDF3"/>
										</TextBlock>
									</Border>

								</StackPanel>
							</ScrollViewer>
						</Border>

						<!-- ╔══════════════════════════════════════╗ -->
						<!-- ║       TAB 1: ОРКЕСТРАТОР            ║ -->
						<!-- ╚══════════════════════════════════════╝ -->
						<Border>
							<Border.Style>
								<Style TargetType="Border">
									<Setter Property="Visibility" Value="Collapsed"/>
									<Setter Property="Opacity" Value="0"/>
									<Style.Triggers>
										<DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
											<Setter Property="Visibility" Value="Visible"/>
											<DataTrigger.EnterActions>
												<BeginStoryboard>
													<Storyboard>
														<DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="0" To="1" Duration="0:0:0.3">
															<DoubleAnimation.EasingFunction>
																<CubicEase EasingMode="EaseOut"/>
															</DoubleAnimation.EasingFunction>
														</DoubleAnimation>
													</Storyboard>
												</BeginStoryboard>
											</DataTrigger.EnterActions>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</Border.Style>
							<ScrollViewer VerticalScrollBarVisibility="Auto">
								<StackPanel Margin="16,12">

									<TextBlock Style="{StaticResource SecH}" Text="УПРАВЛЕНИЕ" Margin="0,0,0,8"/>
									<StackPanel Orientation="Horizontal" Margin="0,0,0,10">
										<Button Margin="0,0,10,0"
                                                Command="{Binding ToggleOrchestratorCommand}">
											<Button.Style>
												<Style TargetType="Button" BasedOn="{StaticResource TermBtn}">
													<Setter Property="Content" Value="▶ Запустить оркестратор"/>
													<Style.Triggers>
														<DataTrigger Binding="{Binding OrchestratorRunning}" Value="True">
															<Setter Property="Content" Value="⏹ Остановить оркестратор"/>
															<Setter Property="BorderBrush" Value="#DA3633"/>
															<Setter Property="Foreground" Value="#F85149"/>
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</Button.Style>
										</Button>
										<Button Content="🔍 Проверить сейчас" Style="{StaticResource TermBtn}"
                                                Command="{Binding CheckNowCommand}"/>
									</StackPanel>

									<StackPanel Orientation="Horizontal" Margin="0,0,0,4">
										<TextBlock Style="{StaticResource Lbl}" Text="Интервал (мин): " Margin="0,0,8,0"/>
										<TextBox Text="{Binding OrchestratorInterval, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="50" Height="26" VerticalContentAlignment="Center"/>
									</StackPanel>
									<StackPanel Orientation="Horizontal" Margin="0,4,0,0">
										<TextBlock Style="{StaticResource Lbl}" Text="Следующая проверка: " Margin="0,0,4,0"/>
										<TextBlock Style="{StaticResource Val}" Text="{Binding OrchestratorNextCheck}"/>
									</StackPanel>

									<Rectangle Style="{StaticResource Sep}"/>

									<TextBlock Style="{StaticResource SecH}" Text="САЙТЫ ДЛЯ ПРОВЕРКИ"/>
									<WrapPanel Margin="0,0,0,8">
										<CheckBox Content="YouTube" IsChecked="{Binding SiteYouTube}" Margin="0,4,16,4"/>
										<CheckBox Content="Discord" IsChecked="{Binding SiteDiscord}" Margin="0,4,16,4"/>
										<CheckBox Content="Google" IsChecked="{Binding SiteGoogle}" Margin="0,4,16,4"/>
										<CheckBox Content="Twitch" IsChecked="{Binding SiteTwitch}" Margin="0,4,16,4"/>
										<CheckBox Content="Instagram" IsChecked="{Binding SiteInstagram}" Margin="0,4,16,4"/>
										<CheckBox Content="Telegram" IsChecked="{Binding SiteTelegram}" Margin="0,4,16,4"/>
									</WrapPanel>

									<Rectangle Style="{StaticResource Sep}"/>

									<TextBlock Style="{StaticResource SecH}" Text="РЕЙТИНГ ПРОФИЛЕЙ"/>
									<Button HorizontalAlignment="Left" Margin="0,0,0,10"
                                            Command="{Binding ScanProfilesCommand}">
										<Button.Style>
											<Style TargetType="Button" BasedOn="{StaticResource AccentBtn}">
												<Setter Property="Content" Value="📊 Сканировать все профили"/>
												<Style.Triggers>
													<DataTrigger Binding="{Binding IsScanning}" Value="True">
														<Setter Property="IsEnabled" Value="False"/>
														<Setter Property="Content" Value="⏳ Сканирование..."/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</Button.Style>
									</Button>

									<TextBlock Text="{Binding ScanProgressText}" FontFamily="Segoe UI" Foreground="#4FC3F7"
                                               FontSize="12" Margin="0,0,0,8"
                                               Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"/>

									<ItemsControl ItemsSource="{Binding ProfileScores}">
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<Border Background="#161B22" Padding="10,6" Margin="0,2">
													<Grid>
														<Grid.ColumnDefinitions>
															<ColumnDefinition Width="*"/>
															<ColumnDefinition Width="Auto"/>
														</Grid.ColumnDefinitions>
														<TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                                   FontFamily="Segoe UI" Foreground="#E6EDF3" FontSize="13"
                                                                   VerticalAlignment="Center"/>
														<TextBlock Grid.Column="1" Text="{Binding ScoreText}"
                                                                   FontFamily="Segoe UI" Foreground="#4FC3F7" FontSize="13"
                                                                   FontWeight="Bold" VerticalAlignment="Center"/>
													</Grid>
												</Border>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>

									<Button Content="🗑 Очистить лог" Style="{StaticResource TermBtn}"
                                            HorizontalAlignment="Left" Margin="0,10,0,0"
                                            Command="{Binding ClearOrchestratorLogsCommand}"/>

									<Border Style="{StaticResource LogArea}" Margin="0,8,0,0">
										<ItemsControl ItemsSource="{Binding OrchestratorLogs}">
											<ItemsControl.ItemTemplate>
												<DataTemplate>
													<TextBlock Text="{Binding}" Foreground="#8B949E"
                                                               FontFamily="Segoe UI" FontSize="11" Margin="0,2"/>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>
									</Border>

								</StackPanel>
							</ScrollViewer>
						</Border>

						<!-- ╔══════════════════════════════════════╗ -->
						<!-- ║       TAB 2: ОБНОВЛЕНИЕ             ║ -->
						<!-- ╚══════════════════════════════════════╝ -->
						<Border>
							<Border.Style>
								<Style TargetType="Border">
									<Setter Property="Visibility" Value="Collapsed"/>
									<Setter Property="Opacity" Value="0"/>
									<Style.Triggers>
										<DataTrigger Binding="{Binding SelectedTabIndex}" Value="3">
											<Setter Property="Visibility" Value="Visible"/>
											<DataTrigger.EnterActions>
												<BeginStoryboard>
													<Storyboard>
														<DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="0" To="1" Duration="0:0:0.3">
															<DoubleAnimation.EasingFunction>
																<CubicEase EasingMode="EaseOut"/>
															</DoubleAnimation.EasingFunction>
														</DoubleAnimation>
													</Storyboard>
												</BeginStoryboard>
											</DataTrigger.EnterActions>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</Border.Style>
							<ScrollViewer VerticalScrollBarVisibility="Auto">
								<StackPanel Margin="16,12">

									<TextBlock Style="{StaticResource SecH}" Text="FLOWSEAL ZAPRET" Margin="0,0,0,8"/>
									<Grid Margin="0,0,0,12">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="140"/>
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>
										<Grid.RowDefinitions>
											<RowDefinition Height="26"/>
											<RowDefinition Height="26"/>
										</Grid.RowDefinitions>
										<TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Lbl}" Text="Текущая версия:"/>
										<TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Val}" Text="{Binding CurrentEngineVersion}"/>
										<TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Lbl}" Text="Статус:"/>
										<TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Val}" Text="{Binding UpdateStatus}"/>
									</Grid>

									<StackPanel Orientation="Horizontal" Margin="0,0,0,12">
										<Button Margin="0,0,10,0"
                                                Command="{Binding CheckUpdatesCommand}">
											<Button.Style>
												<Style TargetType="Button" BasedOn="{StaticResource TermBtn}">
													<Setter Property="Content" Value="🔍 Проверить"/>
													<Style.Triggers>
														<DataTrigger Binding="{Binding IsUpdating}" Value="True">
															<Setter Property="IsEnabled" Value="False"/>
															<Setter Property="Content" Value="⏳ Обновление..."/>
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</Button.Style>
										</Button>
										<Button Command="{Binding InstallUpdatesCommand}">
											<Button.Style>
												<Style TargetType="Button" BasedOn="{StaticResource AccentBtn}">
													<Setter Property="Content" Value="⬆️ Обновить"/>
													<Style.Triggers>
														<DataTrigger Binding="{Binding IsUpdating}" Value="True">
															<Setter Property="IsEnabled" Value="False"/>
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</Button.Style>
										</Button>
									</StackPanel>

									<CheckBox Content="Автоматически проверять при запуске"
                                              IsChecked="{Binding AutoUpdateEnabled}" Margin="0,0,0,12"/>

									<Border Background="#1C1500" BorderBrush="#5A4800" BorderThickness="1"
                                            Padding="10,8" Margin="0,0,0,12">
										<TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="11" Foreground="#FFD700"
                                                   Text="⚠️ При обновлении winws.exe будет остановлен. После установки нужно заново запустить профиль."/>
									</Border>

									<TextBlock Style="{StaticResource SecH}" Text="ЛОГ ОБНОВЛЕНИЯ"/>
									<Border Style="{StaticResource LogArea}">
										<ItemsControl ItemsSource="{Binding UpdateLogs}">
											<ItemsControl.ItemTemplate>
												<DataTemplate>
													<TextBlock Text="{Binding}" Foreground="#8B949E"
                                                               FontFamily="Segoe UI" FontSize="11" Margin="0,2"/>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>
									</Border>

								</StackPanel>
							</ScrollViewer>
						</Border>

						<!-- ╔══════════════════════════════════════╗ -->
						<!-- ║       TAB 3: ДИАГНОСТИКА            ║ -->
						<!-- ╚══════════════════════════════════════╝ -->
						<Border>
							<Border.Style>
								<Style TargetType="Border">
									<Setter Property="Visibility" Value="Collapsed"/>
									<Setter Property="Opacity" Value="0"/>
									<Style.Triggers>
										<DataTrigger Binding="{Binding SelectedTabIndex}" Value="4">
											<Setter Property="Visibility" Value="Visible"/>
											<DataTrigger.EnterActions>
												<BeginStoryboard>
													<Storyboard>
														<DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="0" To="1" Duration="0:0:0.3">
															<DoubleAnimation.EasingFunction>
																<CubicEase EasingMode="EaseOut"/>
															</DoubleAnimation.EasingFunction>
														</DoubleAnimation>
													</Storyboard>
												</BeginStoryboard>
											</DataTrigger.EnterActions>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</Border.Style>
							<ScrollViewer VerticalScrollBarVisibility="Auto">
								<StackPanel Margin="16,12">

									<TextBlock Style="{StaticResource SecH}" Text="СИСТЕМНЫЕ НАСТРОЙКИ" Margin="0,0,0,8"/>

									<CheckBox Content="Запускать FluxRoute при входе в Windows"
                                              IsChecked="{Binding AutoStartEnabled}" Margin="0,4,0,4"/>
									<CheckBox Content="Показывать предупреждение при смене профиля"
                                              IsChecked="{Binding ShowProfileSwitchWarning}" Margin="0,4,0,12"/>

									<Rectangle Style="{StaticResource Sep}"/>

									<TextBlock Style="{StaticResource SecH}" Text="КОМПОНЕНТЫ"/>
									<Grid Margin="0,0,0,12">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="170"/>
											<ColumnDefinition Width="*"/>
