<Window x:Class="FluxRoute.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:FluxRoute.Views.Shell"
    xmlns:tabs="clr-namespace:FluxRoute.Views.Tabs"
    Title="FluxRoute"
    Height="520" Width="860"
    MinHeight="520" MinWidth="860"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <Border x:Name="RootBorder" Background="#0c0f17" BorderBrush="#1C1F2E"
            BorderThickness="1" CornerRadius="16" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <shell:TitleBar Grid.Row="0"
                            MinimizeRequested="TitleBar_MinimizeRequested"
                            CloseRequested="TitleBar_CloseRequested" />

            <Grid Grid.Row="1" Margin="0,0,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="66" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <shell:Sidebar x:Name="SidebarControl" Grid.Column="0" />

                <Border Grid.Column="1" BorderBrush="#1C2030" BorderThickness="1"
                        CornerRadius="14" Margin="8,0,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#11131E" Offset="0" />
                            <GradientStop Color="#0E1018" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Border>
                            <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Setter Property="Opacity" Value="0"/><Style.Triggers><DataTrigger Binding="{Binding SelectedTabIndex}" Value="0"><Setter Property="Visibility" Value="Visible"/><DataTrigger.EnterActions><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/></Storyboard></BeginStoryboard></DataTrigger.EnterActions></DataTrigger></Style.Triggers></Style></Border.Style>
                            <tabs:HomePage x:Name="HomeTab" />
                        </Border>
                        <Border>
                            <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Setter Property="Opacity" Value="0"/><Style.Triggers><DataTrigger Binding="{Binding SelectedTabIndex}" Value="1"><Setter Property="Visibility" Value="Visible"/><DataTrigger.EnterActions><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/></Storyboard></BeginStoryboard></DataTrigger.EnterActions></DataTrigger></Style.Triggers></Style></Border.Style>
                            <tabs:ComponentsPage />
                        </Border>
                        <Border>
                            <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Setter Property="Opacity" Value="0"/><Style.Triggers><DataTrigger Binding="{Binding SelectedTabIndex}" Value="2"><Setter Property="Visibility" Value="Visible"/><DataTrigger.EnterActions><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/></Storyboard></BeginStoryboard></DataTrigger.EnterActions></DataTrigger></Style.Triggers></Style></Border.Style>
                            <tabs:OrchestratorHubPage />
                        </Border>
                        <Border>
                            <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Setter Property="Opacity" Value="0"/><Style.Triggers><DataTrigger Binding="{Binding SelectedTabIndex}" Value="3"><Setter Property="Visibility" Value="Visible"/><DataTrigger.EnterActions><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/></Storyboard></BeginStoryboard></DataTrigger.EnterActions></DataTrigger></Style.Triggers></Style></Border.Style>
                            <tabs:ModsPage />
                        </Border>
                        <Border>
                            <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Setter Property="Opacity" Value="0"/><Style.Triggers><DataTrigger Binding="{Binding SelectedTabIndex}" Value="4"><Setter Property="Visibility" Value="Visible"/><DataTrigger.EnterActions><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/></Storyboard></BeginStoryboard></DataTrigger.EnterActions></DataTrigger></Style.Triggers></Style></Border.Style>
                            <tabs:DiagnosticsPage />
                        </Border>
                        <Border>
                            <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Setter Property="Opacity" Value="0"/><Style.Triggers><DataTrigger Binding="{Binding SelectedTabIndex}" Value="5"><Setter Property="Visibility" Value="Visible"/><DataTrigger.EnterActions><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/></Storyboard></BeginStoryboard></DataTrigger.EnterActions></DataTrigger></Style.Triggers></Style></Border.Style>
                            <tabs:LogsPage x:Name="LogsTab" />
                        </Border>
                        <Border>
                            <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Setter Property="Opacity" Value="0"/><Style.Triggers><DataTrigger Binding="{Binding SelectedTabIndex}" Value="6"><Setter Property="Visibility" Value="Visible"/><DataTrigger.EnterActions><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/></Storyboard></BeginStoryboard></DataTrigger.EnterActions></DataTrigger></Style.Triggers></Style></Border.Style>
                            <tabs:SettingsPage />
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.RowSpan="2" Background="Transparent" Height="6" VerticalAlignment="Top" Cursor="SizeNS" MouseDown="ResizeGrip_MouseDown" Tag="Top" />
            <Border Grid.RowSpan="2" Background="Transparent" Height="6" VerticalAlignment="Bottom" Cursor="SizeNS" MouseDown="ResizeGrip_MouseDown" Tag="Bottom" />
            <Border Grid.RowSpan="2" Background="Transparent" Width="6" HorizontalAlignment="Left" Cursor="SizeWE" MouseDown="ResizeGrip_MouseDown" Tag="Left" />
            <Border Grid.RowSpan="2" Background="Transparent" Width="6" HorizontalAlignment="Right" Cursor="SizeWE" MouseDown="ResizeGrip_MouseDown" Tag="Right" />
            <Border Grid.RowSpan="2" Background="Transparent" Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE" MouseDown="ResizeGrip_MouseDown" Tag="TopLeft" />
            <Border Grid.RowSpan="2" Background="Transparent" Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" MouseDown="ResizeGrip_MouseDown" Tag="TopRight" />
            <Border Grid.RowSpan="2" Background="Transparent" Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" MouseDown="ResizeGrip_MouseDown" Tag="BottomLeft" />
            <Border Grid.RowSpan="2" Background="Transparent" Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" MouseDown="ResizeGrip_MouseDown" Tag="BottomRight" />

            <Grid Grid.RowSpan="2" IsHitTestVisible="{Binding GlobalOverlayVisible}">
                <Grid.Style><Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding GlobalOverlayVisible}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Grid.Style>
                <Border Background="#80000000" CornerRadius="16" />
                <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="12" Width="400" MaxHeight="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24,20">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="{Binding GlobalOverlayTitle}" FontSize="15" FontWeight="SemiBold" Foreground="#C9D1D9" />
                                <Button Content="&#x2715;" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="#8B949E" Command="{Binding GlobalOverlayCloseCommand}" />
                            </Grid>
                            <ContentPresenter Content="{Binding GlobalOverlayContent}" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
