																		<Setter Property="BorderBrush" Value="#DA3633"/>
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</Button.Style>
													</Button>
													<Button Content="🔍 Обновления" Style="{StaticResource TermBtn}"
															Command="{Binding CheckTgProxyUpdatesCommand}"
															IsEnabled="{Binding TgProxyInstalled}"/>
														<Button Content="📲 Открыть в Telegram" Style="{StaticResource AccentBtn}" Margin="10,0,0,0"
															Command="{Binding OpenInTelegramCommand}"
															IsEnabled="{Binding TgProxyRunning}"/>
														<Button Content="📋 Скопировать ссылку" Style="{StaticResource TermBtn}" Margin="10,0,0,0"
															Command="{Binding CopyTgLinkCommand}"
															IsEnabled="{Binding TgProxyInstalled}"/>
												</StackPanel>

												<!-- Статус версии -->
												<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
													<TextBlock Style="{StaticResource Lbl}" Text="Версия: " Margin="0,0,4,0"/>
													<TextBlock Style="{StaticResource Val}" Text="{Binding TgProxyVersion}"/>
												</StackPanel>

												<!-- ЛОГ -->
												<StackPanel Orientation="Horizontal" Margin="0,0,0,6">
													<TextBlock Style="{StaticResource SecH}" Text="ЛОГ" Margin="0,14,12,8"/>
													<Button Content="🗑 Очистить" Style="{StaticResource TermBtn}"
															Padding="8,4" FontSize="11" VerticalAlignment="Center"
															Command="{Binding ClearTgProxyLogsCommand}"/>
												</StackPanel>
												<Border Style="{StaticResource LogArea}" MaxHeight="200">
													<ItemsControl ItemsSource="{Binding TgProxyLogs}">
														<ItemsControl.ItemTemplate>
															<DataTemplate>
																<TextBlock Text="{Binding}" Foreground="#8B949E"
																		   FontFamily="Segoe UI" FontSize="11" Margin="0,2"/>
															</DataTemplate>
														</ItemsControl.ItemTemplate>
													</ItemsControl>
												</Border>

											</StackPanel>
										</ScrollViewer>
									</Border>

							</Grid>
						</Grid>
					</Grid>

					<!-- ═══════════ STATUS BAR ═══════════ -->
			<Border Grid.Row="2" Background="#010409" BorderBrush="#21262D" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,4,4">
				<Grid Margin="14,0">
					<TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#8B949E"
                               VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Run Text="v"/><Run Text="{Binding AppVersion, Mode=OneWay}"/>
					</TextBlock>
					<TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#8B949E"
                               VerticalAlignment="Center" HorizontalAlignment="Right">
						<TextBlock.Style>
							<Style TargetType="TextBlock">
								<Setter Property="Text" Value="Ready"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding IsRunning}" Value="True">
										<Setter Property="Text" Value="● Active"/>
										<Setter Property="Foreground" Value="#3FB950"/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</TextBlock.Style>
					</TextBlock>
				</Grid>
			</Border>

		</Grid>
	</Border>
</Window>
