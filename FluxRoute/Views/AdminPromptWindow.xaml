<Window x:Class="FluxRoute.Views.AdminPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FluxRoute — Требуются права администратора"
        Height="260" Width="460"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="#1E1E1E" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="8">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="⚠️ Требуются права администратора"
                       Foreground="#FFD700" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <!-- Description -->
            <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="#DDDDDD" FontSize="13" Margin="0,0,0,8"
                       Text="Для корректной работы FluxRoute (запуск winws.exe, управление сетевыми фильтрами) необходимы права администратора."/>

            <TextBlock Grid.Row="2" TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="12" VerticalAlignment="Center"
                       Text="Вы можете продолжить без прав, но функциональность будет ограничена."/>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Продолжить без прав" Click="ContinueButton_Click"
                        Background="#2D2D30" Foreground="#AAAAAA" BorderThickness="0"
                        Padding="16,10" FontSize="13" Cursor="Hand" Margin="0,0,10,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="🔒 Перезапустить с правами" Click="RestartAsAdminButton_Click"
                        Background="#0078D4" Foreground="White" BorderThickness="0"
                        Padding="16,10" FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1084D8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
