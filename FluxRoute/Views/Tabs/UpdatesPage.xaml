<UserControl x:Class="FluxRoute.Views.Tabs.UpdatesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="460" d:DesignWidth="760">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,12">
            <TextBlock Style="{StaticResource SecH}" Text="FLOWSEAL ZAPRET" Margin="0,0,0,8" />
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26" />
                    <RowDefinition Height="26" />
                    <RowDefinition Height="26" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Lbl}" Text="Текущая версия:" />
                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Val}" Text="{Binding CurrentEngineVersion}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Lbl}" Text="Доступная версия:" />
                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Val}" Text="{Binding Updates.LatestRemoteVersion}" />
                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Lbl}" Text="Статус:" />
                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource Val}" Text="{Binding UpdateStatus}" />
            </Grid>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Margin="0,0,10,0" Command="{Binding CheckUpdatesCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                            <Setter Property="Content" Value="Проверить" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                    <Setter Property="Content" Value="Обновление..." />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            <CheckBox Content="Автоматически проверять при запуске"
                IsChecked="{Binding AutoUpdateEnabled}" Margin="0,0,0,12" />
            <Border Background="#1C1800" BorderBrush="#4A3800"
                BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,16">
                <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="11" Foreground="#F0B429"
                    Text="При обновлении winws.exe будет остановлен. После установки нужно заново запустить стратегию." />
            </Border>
            <Rectangle Style="{StaticResource Sep}" />

            <TextBlock Style="{StaticResource SecH}" Text="FLUXROUTE (ПРИЛОЖЕНИЕ)" Margin="0,8,0,8" />
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26" />
                    <RowDefinition Height="26" />
                    <RowDefinition Height="26" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Lbl}" Text="Текущая версия:" />
                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Val}" Text="{Binding Updates.CurrentAppVersion}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Lbl}" Text="Доступная версия:" />
                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Val}" Text="{Binding Updates.LatestAppVersion}" />
                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Lbl}" Text="Статус:" />
                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource Val}" Text="{Binding Updates.AppUpdateStatus}" />
            </Grid>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Margin="0,0,10,0" Command="{Binding Updates.CheckAppUpdateCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                            <Setter Property="Content" Value="Проверить" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Updates.IsCheckingAppUpdate}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                    <Setter Property="Content" Value="Проверка..." />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            <Rectangle Style="{StaticResource Sep}" />

            <TextBlock Style="{StaticResource SecH}" Text="TG WS PROXY" Margin="0,8,0,8" />
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26" />
                    <RowDefinition Height="26" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Lbl}" Text="Текущая версия:" />
                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Val}" Text="{Binding TgProxyVersion}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Lbl}" Text="Установлен:" />
                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Val}"
                    Text="{Binding TgProxyInstalled, Converter={StaticResource BoolToInstalled}}" />
            </Grid>
            <Button Content="Проверить" Style="{StaticResource ActionBtn}"
                HorizontalAlignment="Left" Margin="0,0,0,12"
                Command="{Binding CheckTgProxyUpdatesCommand}"
                IsEnabled="{Binding TgProxyInstalled}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
