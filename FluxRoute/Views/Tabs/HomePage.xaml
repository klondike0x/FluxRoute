<UserControl x:Class="FluxRoute.Views.Tabs.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Только основное управление: кнопка, статус, стратегия -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid Width="240" Height="240" HorizontalAlignment="Center">
                <Ellipse Width="220" Height="220" Opacity="0.5">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#203060C0" Offset="0.45" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <Ellipse x:Name="WaveRing1" Width="168" Height="168" Stroke="#55AAFF"
                         StrokeThickness="12" Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="WaveRing1Scale" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse x:Name="WaveRing2" Width="168" Height="168" Stroke="#7755EE"
                         StrokeThickness="8" Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="WaveRing2Scale" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse x:Name="WaveRing3" Width="168" Height="168" Stroke="#9933DD"
                         StrokeThickness="4" Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="WaveRing3Scale" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse Width="168" Height="168" StrokeThickness="3.5">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#55AAFF" Offset="0" />
                            <GradientStop Color="#7755EE" Offset="0.5" />
                            <GradientStop Color="#9933DD" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                </Ellipse>
                <Ellipse Width="152" Height="152" Fill="#10121E" Stroke="#18FFFFFF" />

                <Button Width="152" Height="152" Command="{Binding ToggleStartStopCommand}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="76">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="⏻" FontSize="48" Foreground="#55AAFF"
                                               HorizontalAlignment="Center" />
                                    <TextBlock FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Запустить" />
                                                <Setter Property="Foreground" Value="#DCE4F0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                        <Setter Property="Text" Value="Остановить" />
                                                        <Setter Property="Foreground" Value="#00D68F" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <StackPanel HorizontalAlignment="Center" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#CC3030" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Fill" Value="#00D68F" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontFamily="Segoe UI" FontSize="13" FontWeight="Medium">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Защита не активна" />
                                <Setter Property="Foreground" Value="#8B949E" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Text" Value="Защита активна" />
                                        <Setter Property="Foreground" Value="#00D68F" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <!-- Выбор активной стратегии -->
                <ComboBox ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                          Width="260" Height="30"
                          HorizontalAlignment="Center"
                          Margin="0,8,0,0"
                          Background="#111520"
                          Foreground="#DCE4F0"
                          BorderBrush="#30363D"
                          BorderThickness="1"
                          ToolTip="Выберите стратегию запуска">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}"
                                       Foreground="#DCE4F0"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </StackPanel>

        <!-- Нижняя строка: только аптайм и PID -->
        <Border Grid.Row="1" Background="#0E1120" BorderBrush="#1A1E30"
                BorderThickness="1" CornerRadius="12" Padding="18,10"
                HorizontalAlignment="Center" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="#8B949E" FontSize="11">
                    <Run Text="Аптайм: " />
                    <Run Text="{Binding UptimeText}" Foreground="#DCE4F0" FontWeight="SemiBold" />
                </TextBlock>
                <Rectangle Width="1" Fill="#30363D" Margin="16,0" />
                <TextBlock Foreground="#8B949E" FontSize="11">
                    <Run Text="PID: " />
                    <Run Text="{Binding PidText}" Foreground="#DCE4F0" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
