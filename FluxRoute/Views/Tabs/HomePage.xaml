<UserControl x:Class="FluxRoute.Views.Tabs.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="ProtectionModeSegment" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Foreground" Value="#77849C" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SegmentBackground"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SegmentBackground" Property="Background" Value="#121B2D" />
                                <Setter Property="Foreground" Value="#B9C6DB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SegmentBackground" Property="Background" Value="#0E1626" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="#0A0E18" />
            <Setter Property="BorderBrush" Value="#1C2940" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,11" />
        </Style>

        <Style x:Key="ServiceStatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="7" />
            <Setter Property="Height" Value="7" />
            <Setter Property="Fill" Value="#3B465A" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#66758E" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="10" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DCE4F0" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
    </UserControl.Resources>

    <Grid x:Name="LayoutRoot" Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="HeroColumn" Width="*" />
            <ColumnDefinition x:Name="WideGapColumn" Width="0" />
            <ColumnDefinition x:Name="DetailsColumn" Width="0" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Главный Hero-блок остаётся главным визуальным якорем во всех режимах. -->
        <StackPanel x:Name="HeroPanel"
                    Grid.Row="0" Grid.Column="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Grid Width="200" Height="200" HorizontalAlignment="Center">
                <Ellipse Width="190" Height="190" Opacity="0.5">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#203060C0" Offset="0.45" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <Ellipse x:Name="WaveRing1" Width="168" Height="168" Stroke="#55AAFF"
                         StrokeThickness="12" Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform><ScaleTransform x:Name="WaveRing1Scale" /></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse x:Name="WaveRing2" Width="168" Height="168" Stroke="#7755EE"
                         StrokeThickness="8" Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform><ScaleTransform x:Name="WaveRing2Scale" /></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse x:Name="WaveRing3" Width="168" Height="168" Stroke="#9933DD"
                         StrokeThickness="4" Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform><ScaleTransform x:Name="WaveRing3Scale" /></Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse Width="168" Height="168" StrokeThickness="3.5">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#55AAFF" Offset="0" />
                            <GradientStop Color="#7755EE" Offset="0.5" />
                            <GradientStop Color="#9933DD" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                </Ellipse>
                <Ellipse Width="152" Height="152" Fill="#10121E" Stroke="#18FFFFFF" />

                <Button Width="152" Height="152" Command="{Binding ToggleStartStopCommand}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonSurface" Background="Transparent" CornerRadius="76">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="⏻" FontSize="48" Foreground="#55AAFF" HorizontalAlignment="Center" />
                                    <TextBlock FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Запустить" />
                                                <Setter Property="Foreground" Value="#DCE4F0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                        <Setter Property="Text" Value="Остановить" />
                                                        <Setter Property="Foreground" Value="#00D68F" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonSurface" Property="Opacity" Value="0.85" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <StackPanel HorizontalAlignment="Center" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#CC3030" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Fill" Value="#00D68F" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontFamily="Segoe UI" FontSize="13" FontWeight="Medium">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Защита не активна" />
                                <Setter Property="Foreground" Value="#8B949E" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Text" Value="Защита активна" />
                                        <Setter Property="Foreground" Value="#00D68F" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <ToggleButton x:Name="ModeToggleButton"
                              IsChecked="{Binding IsOpen, ElementName=ProtectionModePopup, Mode=TwoWay}"
                              HorizontalAlignment="Center" Margin="0,8,0,0" Cursor="Hand"
                              ToolTip="Изменить режим защиты и стратегию">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="ModeSurface" Background="#0D1422" BorderBrush="#253553"
                                    BorderThickness="1" CornerRadius="9" Padding="11,6">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Fill="#4D6BFE" Margin="0,0,7,0" VerticalAlignment="Center" />
                                    <TextBlock FontFamily="Segoe UI" FontSize="10.5" FontWeight="SemiBold"
                                               Foreground="#A9B7CD" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Автовыбор" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsManualProtectionMode}" Value="True">
                                                        <Setter Property="Text" Value="Вручную" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text=" · " Foreground="#4B5870" FontSize="10.5" />
                                    <TextBlock Text="{Binding SelectedProfile.DisplayName, FallbackValue=Стратегия не выбрана}"
                                               Foreground="#7E8DA5" FontFamily="Segoe UI" FontSize="10.5"
                                               MaxWidth="150" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="⌄" Foreground="#66758E" FontSize="12" Margin="8,-1,0,0" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ModeSurface" Property="Background" Value="#111A2B" />
                                    <Setter TargetName="ModeSurface" Property="BorderBrush" Value="#405785" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ModeSurface" Property="BorderBrush" Value="#4D6BFE" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
                <TextBlock HorizontalAlignment="Center" Margin="0,6,0,0" FontFamily="Segoe UI"
                           FontSize="10" Foreground="#5D6B82">
                    <Run Text="Аптайм  " />
                    <Run Text="{Binding UptimeText}" Foreground="#8997AD" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- Одинаковое всплывающее управление режимом доступно из Hero в обоих layout. -->
        <Popup x:Name="ProtectionModePopup"
               PlacementTarget="{Binding ElementName=ModeToggleButton}"
               Placement="Right" HorizontalOffset="10" VerticalOffset="-132"
               AllowsTransparency="True" StaysOpen="False" PopupAnimation="Fade">
        <Border x:Name="ProtectionModeCard"
                Style="{StaticResource DashboardCard}"
                Width="280"
                Padding="8"
                Background="#0B101B"
                BorderBrush="#33466D">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="6,2,6,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Режим защиты" Foreground="#DCE4F0" FontSize="11" FontWeight="SemiBold" />
                        <TextBlock Text="Управление стратегией FluxRoute" Foreground="#55647D" FontSize="9.5" Margin="0,2,0,0" />
                    </StackPanel>
                    <Ellipse Grid.Column="1" Width="7" Height="7" Fill="#4D6BFE" VerticalAlignment="Center" Margin="20,0,0,0" />
                </Grid>

                <Border Grid.Row="1" Background="#0D1422" CornerRadius="10" Padding="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" HorizontalAlignment="Stretch" Command="{Binding SelectAutomaticProtectionModeCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProtectionModeSegment}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAutomaticProtectionMode}" Value="True">
                                            <Setter Property="Foreground" Value="#F3F6FF" />
                                            <Setter Property="Background" Value="#26355F" />
                                            <Setter Property="BorderBrush" Value="#4D6BFE" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◈" FontSize="13" Margin="0,0,6,0" />
                                <TextBlock Text="Автовыбор" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" HorizontalAlignment="Stretch" Command="{Binding SelectManualProtectionModeCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProtectionModeSegment}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsManualProtectionMode}" Value="True">
                                            <Setter Property="Foreground" Value="#F3F6FF" />
                                            <Setter Property="Background" Value="#24233C" />
                                            <Setter Property="BorderBrush" Value="#7755EE" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="≡" FontSize="15" Margin="0,0,6,0" />
                                <TextBlock Text="Вручную" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2" Margin="4,8,4,2">
                    <Grid Margin="2,0,2,5">
                        <TextBlock Text="Стратегия" Foreground="#8997AD" FontSize="9.5" />
                        <TextBlock HorizontalAlignment="Right" FontSize="9.5">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Выбор вручную" />
                                    <Setter Property="Foreground" Value="#7755EE" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAutomaticProtectionMode}" Value="True">
                                            <Setter Property="Text" Value="Управляет оркестратор" />
                                            <Setter Property="Foreground" Value="#4B5870" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <ComboBox ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                              IsEnabled="{Binding IsManualProtectionMode}"
                              Height="31"
                              HorizontalAlignment="Stretch"
                              ToolTip="В режиме «Вручную» можно выбрать стратегию запуска">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                <Setter Property="Background" Value="#111827" />
                                <Setter Property="Foreground" Value="#DCE4F0" />
                                <Setter Property="BorderBrush" Value="#3B4A65" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Opacity" Value="1" />
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#151D2B" />
                                        <Setter Property="Foreground" Value="#95A2B5" />
                                        <Setter Property="BorderBrush" Value="#566680" />
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="ToolTip" Value="Стратегию выбирает оркестратор. Переключитесь на «Вручную», чтобы изменить её." />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" Foreground="#DCE4F0" FontSize="12" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>
        </Popup>

        <!-- В широком режиме справа появляется оперативная сводка служб. -->
        <Border x:Name="ServicesCard"
                Grid.Row="0" Grid.Column="2"
                Style="{StaticResource DashboardCard}"
                Margin="0,0,0,174"
                VerticalAlignment="Stretch"
                Visibility="Collapsed"
                Opacity="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Активные службы" Foreground="#DCE4F0" FontSize="12" FontWeight="SemiBold" />
                <TextBlock Grid.Row="1" Text="Состояние компонентов FluxRoute" Foreground="#55647D" FontSize="9.5" Margin="0,2,0,10" />
                <StackPanel Grid.Row="2">
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Ellipse>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse" BasedOn="{StaticResource ServiceStatusDot}">
                                    <Style.Triggers><DataTrigger Binding="{Binding OrchestratorEnabled}" Value="True"><Setter Property="Fill" Value="#35D79A"/></DataTrigger></Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Grid.Column="1" Text="Оркестратор" Foreground="#A9B5C8" FontSize="11" />
                        <TextBlock Grid.Column="2" FontSize="10">
                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Text" Value="Выключен"/><Setter Property="Foreground" Value="#66758E"/><Style.Triggers><DataTrigger Binding="{Binding OrchestratorEnabled}" Value="True"><Setter Property="Text" Value="Включён"/><Setter Property="Foreground" Value="#62E6B1"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Ellipse>
                            <Ellipse.Style><Style TargetType="Ellipse" BasedOn="{StaticResource ServiceStatusDot}"><Style.Triggers><DataTrigger Binding="{Binding TgProxyRunning}" Value="True"><Setter Property="Fill" Value="#35D79A"/></DataTrigger></Style.Triggers></Style></Ellipse.Style>
                        </Ellipse>
                        <TextBlock Grid.Column="1" Text="Telegram-прокси" Foreground="#A9B5C8" FontSize="11" />
                        <TextBlock Grid.Column="2" FontSize="10">
                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Text" Value="Остановлен"/><Setter Property="Foreground" Value="#66758E"/><Style.Triggers><DataTrigger Binding="{Binding TgProxyRunning}" Value="True"><Setter Property="Text" Value="Работает"/><Setter Property="Foreground" Value="#62E6B1"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Ellipse>
                            <Ellipse.Style><Style TargetType="Ellipse" BasedOn="{StaticResource ServiceStatusDot}"><Style.Triggers><DataTrigger Binding="{Binding GameFilterEnabled}" Value="True"><Setter Property="Fill" Value="#35D79A"/></DataTrigger></Style.Triggers></Style></Ellipse.Style>
                        </Ellipse>
                        <TextBlock Grid.Column="1" Text="Игровой режим" Foreground="#A9B5C8" FontSize="11" />
                        <TextBlock Grid.Column="2" FontSize="10">
                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Text" Value="Выключен"/><Setter Property="Foreground" Value="#66758E"/><Style.Triggers><DataTrigger Binding="{Binding GameFilterEnabled}" Value="True"><Setter Property="Text" Value="Включён"/><Setter Property="Foreground" Value="#62E6B1"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Compact: под Hero расположен ряд из профиля, служб и сети. -->
        <Grid x:Name="CompactSummaryPanel"
              Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
              Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource DashboardCard}" Padding="12,10">
                <StackPanel>
                    <TextBlock Text="ПРОФИЛЬ" Style="{StaticResource MetricLabel}" />
                    <TextBlock Text="{Binding SelectedProfile.DisplayName, FallbackValue=Не выбран}"
                               Style="{StaticResource MetricValue}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource DashboardCard}" Padding="12,10">
                <StackPanel>
                    <TextBlock Text="СЛУЖБЫ" Style="{StaticResource MetricLabel}" />
                    <TextBlock Text="{Binding ActiveServicesSummary}" Style="{StaticResource MetricValue}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource DashboardCard}" Padding="12,10">
                <StackPanel>
                    <TextBlock Text="СЕТЬ / ПИНГ" Style="{StaticResource MetricLabel}" />
                    <TextBlock Text="{Binding CompactNetworkSummary}" Style="{StaticResource MetricValue}"
                               TextWrapping="Wrap" LineHeight="17" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Wide: мини-монитор располагается в правой колонке под активными службами. -->
        <Border x:Name="MetricsCard"
                Grid.Row="0" Grid.Column="2"
                Style="{StaticResource DashboardCard}"
                Padding="8"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#0D1422" BorderBrush="#1C2940"
                        BorderThickness="1" CornerRadius="8" Padding="10,7">
                    <Grid>
                        <TextBlock Style="{StaticResource MetricLabel}" Text="ПИНГ" VerticalAlignment="Center" />
                        <TextBlock Style="{StaticResource MetricValue}" Text="{Binding PingSummary}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0" />
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#0D1422" BorderBrush="#1C2940"
                        BorderThickness="1" CornerRadius="8" Padding="10,7">
                    <Grid>
                        <TextBlock Style="{StaticResource MetricLabel}" Text="АКТИВНЫЕ СЛУЖБЫ" VerticalAlignment="Center" />
                        <TextBlock Style="{StaticResource MetricValue}" Text="{Binding ActiveServicesSummary}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0" />
                    </Grid>
                </Border>

                <Border Grid.Row="4" Background="#0D1422" BorderBrush="#1C2940"
                        BorderThickness="1" CornerRadius="8" Padding="10,7">
                    <Grid>
                        <TextBlock Style="{StaticResource MetricLabel}" Text="СКОРОСТЬ" VerticalAlignment="Center" />
                        <TextBlock Style="{StaticResource MetricValue}" Text="{Binding TrafficSpeedSummary}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
