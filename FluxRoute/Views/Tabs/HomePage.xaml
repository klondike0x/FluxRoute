<UserControl x:Class="FluxRoute.Views.Tabs.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="12,10,12,8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="258" />
        </Grid.ColumnDefinitions>

        <!-- ── LEFT: Power button area ── -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="72" />
                <RowDefinition Height="6" />
            </Grid.RowDefinitions>

            <!-- Engine download banner (top) -->
            <Border Grid.Row="0" Background="#1C1800" BorderBrush="#4A3800"
                    BorderThickness="1" CornerRadius="10" Padding="12,8"
                    VerticalAlignment="Top"
                    Visibility="{Binding IsDownloadingEngine, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="⬇  Первый запуск — скачиваем Flowseal..."
                               FontFamily="Segoe UI" Foreground="#F0B429" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,3" />
                    <TextBlock Text="{Binding EngineDownloadStatus}"
                               FontFamily="Segoe UI" Foreground="#A07820" FontSize="11"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- POWER BUTTON — centered in Row 0 -->
            <Grid Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Deep background ambient glow -->
                <Ellipse Width="240" Height="240">
                    <Ellipse.Fill>
                        <RadialGradientBrush GradientOrigin="0.5,0.5"
                                             Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                            <GradientStop Color="#00000000" Offset="0.2" />
                            <GradientStop Color="#1A3060C0" Offset="0.52" />
                            <GradientStop Color="#1A6030B0" Offset="0.72" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Outer wide soft glow ring -->
                <Ellipse Width="182" Height="182" StrokeThickness="16">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#AA55AAFF" Offset="0" />
                            <GradientStop Color="#887755EE" Offset="0.5" />
                            <GradientStop Color="#AA8833DD" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                    <Ellipse.Effect>
                        <BlurEffect Radius="18" />
                    </Ellipse.Effect>
                </Ellipse>

                <!-- Wave rings (animated from code-behind on IsRunning change) -->
                <Ellipse x:Name="WaveRing1" Width="168" Height="168"
                         StrokeThickness="14" Opacity="0"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#55AAFF" Offset="0" />
                            <GradientStop Color="#AA44FF" Offset="0.5" />
                            <GradientStop Color="#FF3399" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                    <Ellipse.Effect>
                        <BlurEffect Radius="9" />
                    </Ellipse.Effect>
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="WaveRing1Scale" ScaleX="1" ScaleY="1" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse x:Name="WaveRing2" Width="168" Height="168"
                         StrokeThickness="9" Opacity="0"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                            <GradientStop Color="#9933DD" Offset="0" />
                            <GradientStop Color="#4488FF" Offset="0.5" />
                            <GradientStop Color="#FF44AA" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                    <Ellipse.Effect>
                        <BlurEffect Radius="6" />
                    </Ellipse.Effect>
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="WaveRing2Scale" ScaleX="1" ScaleY="1" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse x:Name="WaveRing3" Width="168" Height="168"
                         StrokeThickness="5" Opacity="0"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                            <GradientStop Color="#FF3399" Offset="0" />
                            <GradientStop Color="#9933DD" Offset="0.5" />
                            <GradientStop Color="#55AAFF" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                    <Ellipse.Effect>
                        <BlurEffect Radius="3" />
                    </Ellipse.Effect>
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="WaveRing3Scale" ScaleX="1" ScaleY="1" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Sharp crisp ring -->
                <Ellipse Width="168" Height="168" StrokeThickness="3.5">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#55AAFF" Offset="0" />
                            <GradientStop Color="#7755EE" Offset="0.5" />
                            <GradientStop Color="#9933DD" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                </Ellipse>

                <!-- Inner dark disk -->
                <Ellipse Width="152" Height="152">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#1A1D2C" Offset="0" />
                            <GradientStop Color="#10121E" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Subtle concentric inner outline -->
                <Ellipse Width="152" Height="152" StrokeThickness="1" Stroke="#18FFFFFF" />

                <!-- Power icon button -->
                <Button Width="152" Height="152"
                        Command="{Binding ToggleStartStopCommand}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" x:Name="Bd">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Viewbox Width="54" Height="54">
                                        <Canvas Width="24" Height="24">
                                            <!-- Arc (300°) -->
                                            <Path x:Name="Arc" StrokeThickness="1.5" Fill="Transparent"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                                <Path.Stroke>
                                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                        <GradientStop Color="#55AAFF" Offset="0" />
                                                        <GradientStop Color="#9933DD" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Path.Stroke>
                                                <Path.Data>
                                                    <PathGeometry>
                                                        <PathFigure StartPoint="15.5,5.2" IsClosed="False">
                                                            <ArcSegment Point="8.5,5.2" Size="8,8"
                                                                        SweepDirection="Clockwise" IsLargeArc="True" />
                                                        </PathFigure>
                                                    </PathGeometry>
                                                </Path.Data>
                                                <Path.Effect>
                                                    <DropShadowEffect Color="#55AAFF" BlurRadius="5"
                                                                      ShadowDepth="0" Opacity="0.8" />
                                                </Path.Effect>
                                            </Path>
                                            <!-- Power stem -->
                                            <Line x:Name="PowerLine" X1="12" Y1="2.5" X2="12" Y2="8"
                                                  StrokeThickness="1.5"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                                <Line.Stroke>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#55AAFF" Offset="0" />
                                                        <GradientStop Color="#7755EE" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Line.Stroke>
                                                <Line.Effect>
                                                    <DropShadowEffect Color="#55AAFF" BlurRadius="5"
                                                                      ShadowDepth="0" Opacity="0.8" />
                                                </Line.Effect>
                                            </Line>
                                        </Canvas>
                                    </Viewbox>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter TargetName="Arc" Property="Stroke" Value="#00D68F" />
                                    <Setter TargetName="PowerLine" Property="Stroke" Value="#00D68F" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Row 1: Status pill -->
            <Border Grid.Row="1" HorizontalAlignment="Center"
                    Background="#0A0D1A" BorderBrush="#1E2440"
                    BorderThickness="1" CornerRadius="16" Padding="24,7">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#CC3030" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Fill" Value="#00D68F" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                        <Ellipse.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="#00D68F" Opacity="0.6" />
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock FontFamily="Segoe UI" FontSize="11.5"
                               VerticalAlignment="Center" FontWeight="Medium">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Защита не активна" />
                                <Setter Property="Foreground" Value="#506080" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Text" Value="Защита активна" />
                                        <Setter Property="Foreground" Value="#00D68F" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Row 3: Bottom stats strip -->
            <Grid Grid.Row="3" Margin="0,0,0,8">
                <!-- Subtle top accent line -->
                <Rectangle Height="1" VerticalAlignment="Top"
                           HorizontalAlignment="Stretch" Margin="0,0,0,0" Opacity="0.5">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00000000" Offset="0" />
                            <GradientStop Color="#304A80E2" Offset="0.35" />
                            <GradientStop Color="#308040CC" Offset="0.65" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Cards container -->
                <Border BorderBrush="#1A1E30" BorderThickness="1" CornerRadius="14" Margin="0,4,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#0E1120" Offset="0" />
                            <GradientStop Color="#0B0E1A" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Card: Profile -->
                        <Border Grid.Column="0" CornerRadius="14,0,0,14" Cursor="Arrow" Background="Transparent">
                            <Grid Margin="14,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <Viewbox Width="18" Height="18" Stretch="Uniform"
                                             HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="M8,1.5 L13,3.5 V7.7 C13,10.5 10.9,13.1 8,14.5 C5.1,13.1 3,10.5 3,7.7 V3.5 Z"
                                              Fill="Transparent" Stroke="#00C47A" StrokeThickness="1.7"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                            <Path.Effect>
                                                <DropShadowEffect Color="#00D68F" BlurRadius="10" ShadowDepth="0" Opacity="0.6" />
                                            </Path.Effect>
                                        </Path>
                                    </Viewbox>
                                </Grid>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,0,0">
                                    <TextBlock Text="{Binding SelectedScriptName}"
                                               FontFamily="Segoe UI" FontSize="11" Foreground="#C0CEEC"
                                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis" TextAlignment="Left" />
                                    <TextBlock Text="Профиль" FontFamily="Segoe UI" FontSize="9.5"
                                               Foreground="#2E3C5A" Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Separator -->
                        <Rectangle Grid.Column="0" Width="1" HorizontalAlignment="Right" Margin="0,12">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00000000" Offset="0" />
                                    <GradientStop Color="#1E2A44" Offset="0.5" />
                                    <GradientStop Color="#00000000" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Card: Uptime -->
                        <Border Grid.Column="1" Cursor="Arrow" Background="Transparent">
                            <Grid HorizontalAlignment="Left" Margin="14,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <Viewbox Width="18" Height="18" Stretch="Uniform"
                                             HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Grid Width="16" Height="16">
                                            <Rectangle Width="12" Height="3" RadiusX="0.8" RadiusY="0.8"
                                                       Stroke="#8040CC" StrokeThickness="1.4" Fill="Transparent"
                                                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,1,0,0" />
                                            <Rectangle Width="12" Height="3" RadiusX="0.8" RadiusY="0.8"
                                                       Stroke="#8040CC" StrokeThickness="1.4" Fill="Transparent"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <Rectangle Width="12" Height="3" RadiusX="0.8" RadiusY="0.8"
                                                       Stroke="#8040CC" StrokeThickness="1.4" Fill="Transparent"
                                                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,1" />
                                            <Ellipse Width="1.5" Height="1.5" Fill="#8040CC"
                                                     HorizontalAlignment="Left" VerticalAlignment="Top" Margin="3.3,2.2,0,0" />
                                            <Ellipse Width="1.5" Height="1.5" Fill="#8040CC"
                                                     HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3.3,0,0,0" />
                                            <Ellipse Width="1.5" Height="1.5" Fill="#8040CC"
                                                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="3.3,0,0,2.2" />
                                            <Grid.Effect>
                                                <DropShadowEffect Color="#9B5DE5" BlurRadius="10" ShadowDepth="0" Opacity="0.6" />
                                            </Grid.Effect>
                                        </Grid>
                                    </Viewbox>
                                </Grid>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,0,0">
                                    <TextBlock Text="{Binding UptimeText, Mode=OneWay}"
                                               FontFamily="Segoe UI" FontSize="11" Foreground="#C0CEEC"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Uptime" FontFamily="Segoe UI" FontSize="9.5"
                                               Foreground="#2E3C5A" Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Separator -->
                        <Rectangle Grid.Column="1" Width="1" HorizontalAlignment="Right" Margin="0,12">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00000000" Offset="0" />
                                    <GradientStop Color="#1E2A44" Offset="0.5" />
                                    <GradientStop Color="#00000000" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Card: PID -->
                        <Border Grid.Column="2" CornerRadius="0,14,14,0" Cursor="Arrow" Background="Transparent">
                            <Grid HorizontalAlignment="Left" Margin="14,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <Viewbox Width="18" Height="18" Stretch="Uniform"
                                             HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="M9.2,1.5 L4.6,8.1 H8 L6.8,14.5 L11.4,7.9 H8.1 Z"
                                              Fill="Transparent" Stroke="#D4A020" StrokeThickness="1.8"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                            <Path.Effect>
                                                <DropShadowEffect Color="#F0B429" BlurRadius="10" ShadowDepth="0" Opacity="0.5" />
                                            </Path.Effect>
                                        </Path>
                                    </Viewbox>
                                </Grid>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,0,0">
                                    <TextBlock Text="{Binding PidText, Mode=OneWay}"
                                               FontFamily="Segoe UI" FontSize="11" Foreground="#C0CEEC"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="PID" FontFamily="Segoe UI" FontSize="9.5"
                                               Foreground="#2E3C5A" Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ── RIGHT: Cards ── -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Card 1: Profile selector -->
            <Border Grid.Row="0" Background="#0E1120" BorderBrush="#1A1E30"
                    BorderThickness="1" CornerRadius="12" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Text="" Foreground="#4A80CC" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox Grid.Column="1" ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                              Height="26" Padding="4,2" Background="Transparent" BorderThickness="0"
                              Foreground="#8AA0C8" FontFamily="Segoe UI" FontSize="12" VerticalAlignment="Center">
                        <ComboBox.Template>
                            <ControlTemplate TargetType="ComboBox">
                                <Grid>
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0"
                                                              Content="{TemplateBinding SelectionBoxItem}"
                                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                              VerticalAlignment="Center" Margin="0,0,2,0">
                                                <ContentPresenter.Resources>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#8AA0C8" />
                                                        <Setter Property="FontFamily" Value="Segoe UI" />
                                                        <Setter Property="FontSize" Value="12" />
                                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                    </Style>
                                                </ContentPresenter.Resources>
                                            </ContentPresenter>
                                            <TextBlock Grid.Column="1" Text="▾" Foreground="#3A5080"
                                                       FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                          Background="Transparent" BorderThickness="0" Cursor="Hand" Opacity="0" />
                                        </Grid>
                                    </Border>
                                    <Popup IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True"
                                           Focusable="False" Placement="Bottom" PopupAnimation="Slide">
                                        <Border Background="#111828" BorderBrush="#1E2A40" BorderThickness="1"
                                                CornerRadius="8" Margin="0,3,0,0"
                                                MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="4" Opacity="0.5" />
                                            </Border.Effect>
                                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                                <ItemsPresenter />
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#0E1830" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ComboBox.Template>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="#C8D4EC" Padding="6,5" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="2" Command="{Binding LoadProfilesCommand}"
                            Width="26" Height="26" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="Обновить список профилей" VerticalAlignment="Center" Margin="6,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="Transparent" CornerRadius="6">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text=""
                                               FontSize="13" Foreground="#3A5080"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#0E1830" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Card 2: Toggles -->
            <Border Grid.Row="4" Background="#0E1120" BorderBrush="#1A1E30"
                    BorderThickness="1" CornerRadius="12" Padding="14,12">
                <StackPanel>
                    <!-- GameFilter -->
                    <Grid Margin="0,0,0,11">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="26" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="22" Height="22" CornerRadius="6"
                                Background="#0E1428" BorderBrush="#1A2244" BorderThickness="1">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text=""
                                       Foreground="#4A7ECC" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="Game Filter" FontFamily="Segoe UI"
                                   FontSize="11.5" Foreground="#8090B8" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <CheckBox Grid.Column="2" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding GameFilterEnabled, Mode=OneWay}"
                                  Command="{Binding Service.ToggleGameFilterCommand}" />
                    </Grid>

                    <!-- Orchestrator -->
                    <Grid Margin="0,0,0,11">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="26" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="22" Height="22" CornerRadius="6"
                                Background="#100E28" BorderBrush="#201840" BorderThickness="1">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text=""
                                       Foreground="#8040D8" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="Оркестратор" FontFamily="Segoe UI"
                                   FontSize="11.5" Foreground="#8090B8" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <CheckBox Grid.Column="2" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding OrchestratorEnabled, Mode=TwoWay}" />
                    </Grid>

                    <!-- TG WS Proxy -->
                    <Grid Margin="0,0,0,11">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="26" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="22" Height="22" CornerRadius="6"
                                Background="#0A1620" BorderBrush="#143040" BorderThickness="1">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text=""
                                       Foreground="#2FC8D8" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="TG WS Proxy" FontFamily="Segoe UI"
                                   FontSize="11.5" Foreground="#8090B8" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <CheckBox Grid.Column="2" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding TgProxyRunning, Mode=OneWay}"
                                  Command="{Binding ToggleTgProxyCommand}"
                                  IsEnabled="{Binding TgProxyInstalled}" />
                    </Grid>

                    <!-- AutoStart -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="26" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="22" Height="22" CornerRadius="6"
                                Background="#0A1420" BorderBrush="#142030" BorderThickness="1">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text=""
                                       Foreground="#3A9090" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="Автозапуск" FontFamily="Segoe UI"
                                   FontSize="11.5" Foreground="#8090B8" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <CheckBox Grid.Column="2" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding AutoStartEnabled}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Card 3: System status -->
            <Border Grid.Row="2" Background="#0E1120" BorderBrush="#1A1E30"
                    BorderThickness="1" CornerRadius="12" Padding="14,10">
                <StackPanel>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="7" Height="7" Fill="#5BADFF"
                                 Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="Права доступа" FontFamily="Segoe UI"
                                   FontSize="11" Foreground="#4A5A7A" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding AdminText}" FontFamily="Segoe UI"
                                   FontSize="11" Foreground="#7A90B8" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="7" Height="7" Fill="#8040CC"
                                 Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="WinDivert" FontFamily="Segoe UI"
                                   FontSize="11" Foreground="#4A5A7A" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding WinwsText}" FontFamily="Segoe UI"
                                   FontSize="11" Foreground="#7A90B8" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="7" Height="7" Fill="#00C47A"
                                 Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="Движок" FontFamily="Segoe UI"
                                   FontSize="11" Foreground="#4A5A7A" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding CurrentEngineVersion, Mode=OneWay}"
                                   FontFamily="Segoe UI" FontSize="11" Foreground="#7A90B8" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="7" Height="7" Fill="#2FC8D8"
                                 Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="TG WS Proxy" FontFamily="Segoe UI"
                                   FontSize="11" Foreground="#4A5A7A" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding TgProxyVersion}"
                                   FontFamily="Segoe UI" FontSize="11" Foreground="#7A90B8" HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>