<UserControl x:Class="FluxRoute.Views.Tabs.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Сегмент режима: собственная геометрия FluxRoute, не копия Zapret-Hub. -->
        <Style x:Key="ProtectionModeSegment" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Foreground" Value="#77849C" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SegmentBackground"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SegmentBackground" Property="Background" Value="#121B2D" />
                                <Setter Property="Foreground" Value="#B9C6DB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SegmentBackground" Property="Background" Value="#0E1626" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Быстрый компонент режима закреплён сверху справа -->
        <!-- Быстрое переключение ручного и автоматического управления -->
        <Border Grid.Row="0"
                Background="#0A0E18"
                BorderBrush="#1C2940"
                BorderThickness="1"
                CornerRadius="12"
                Padding="6"
                Width="252"
                Margin="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="6,2,6,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Режим защиты"
                                   Foreground="#DCE4F0"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Управление стратегией FluxRoute"
                                   Foreground="#55647D"
                                   FontFamily="Segoe UI"
                                   FontSize="9.5"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                    <Ellipse Grid.Column="1" Width="7" Height="7"
                             Fill="#4D6BFE" VerticalAlignment="Center" Margin="20,0,0,0" />
                </Grid>

                <Border Grid.Row="1" Background="#0D1422" CornerRadius="10" Padding="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Command="{Binding SelectAutomaticProtectionModeCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProtectionModeSegment}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAutomaticProtectionMode}" Value="True">
                                            <Setter Property="Foreground" Value="#F3F6FF" />
                                            <Setter Property="Background" Value="#26355F" />
                                            <Setter Property="BorderBrush" Value="#4D6BFE" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◈" FontSize="13" Margin="0,0,7,0" />
                                <TextBlock Text="Автовыбор" FontSize="11.5" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                Command="{Binding SelectManualProtectionModeCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProtectionModeSegment}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsManualProtectionMode}" Value="True">
                                            <Setter Property="Foreground" Value="#F3F6FF" />
                                            <Setter Property="Background" Value="#24233C" />
                                            <Setter Property="BorderBrush" Value="#7755EE" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="≡" FontSize="15" Margin="0,0,7,0" />
                                <TextBlock Text="Вручную" FontSize="11.5" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Выбранная стратегия всегда видна внутри быстрого компонента.
                     В автоматическом режиме поле визуально приглушено и недоступно. -->
                <StackPanel Grid.Row="2" Margin="4,9,4,2">
                    <Grid Margin="2,0,2,5">
                        <TextBlock Text="Стратегия"
                                   Foreground="#8997AD"
                                   FontFamily="Segoe UI"
                                   FontSize="9.5" />
                        <TextBlock HorizontalAlignment="Right"
                                   FontFamily="Segoe UI"
                                   FontSize="9.5">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Выбор вручную" />
                                    <Setter Property="Foreground" Value="#7755EE" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAutomaticProtectionMode}" Value="True">
                                            <Setter Property="Text" Value="Управляет оркестратор" />
                                            <Setter Property="Foreground" Value="#4B5870" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <ComboBox ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                              IsEnabled="{Binding IsManualProtectionMode}"
                              Height="31"
                              HorizontalAlignment="Stretch"
                              ToolTip="В режиме «Вручную» можно выбрать стратегию запуска">
                        <ComboBox.Style>
                            <!-- Наследуем общий тёмный шаблон InputStyles.xaml.
                                 Без BasedOn WPF использовал светлый системный disabled-шаблон. -->
                            <Style TargetType="ComboBox"
                                   BasedOn="{StaticResource {x:Type ComboBox}}">
                                <Setter Property="Background" Value="#111827" />
                                <Setter Property="Foreground" Value="#DCE4F0" />
                                <Setter Property="BorderBrush" Value="#3B4A65" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Opacity" Value="1" />
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#151D2B" />
                                        <Setter Property="Foreground" Value="#95A2B5" />
                                        <Setter Property="BorderBrush" Value="#566680" />
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="ToolTip" Value="Стратегию выбирает оркестратор. Переключитесь на «Вручную», чтобы изменить её." />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="#DCE4F0"
                                           FontFamily="Segoe UI"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>


        <!-- Только основное управление: кнопка, статус, стратегия -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid Width="200" Height="200" HorizontalAlignment="Center">
                <Ellipse Width="190" Height="190" Opacity="0.5">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#203060C0" Offset="0.45" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <Ellipse x:Name="WaveRing1" Width="168" Height="168" Stroke="#55AAFF"
                         StrokeThickness="12" Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="WaveRing1Scale" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse x:Name="WaveRing2" Width="168" Height="168" Stroke="#7755EE"
                         StrokeThickness="8" Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="WaveRing2Scale" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse x:Name="WaveRing3" Width="168" Height="168" Stroke="#9933DD"
                         StrokeThickness="4" Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="WaveRing3Scale" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse Width="168" Height="168" StrokeThickness="3.5">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#55AAFF" Offset="0" />
                            <GradientStop Color="#7755EE" Offset="0.5" />
                            <GradientStop Color="#9933DD" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                </Ellipse>
                <Ellipse Width="152" Height="152" Fill="#10121E" Stroke="#18FFFFFF" />

                <Button Width="152" Height="152" Command="{Binding ToggleStartStopCommand}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="76">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="⏻" FontSize="48" Foreground="#55AAFF"
                                               HorizontalAlignment="Center" />
                                    <TextBlock FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Запустить" />
                                                <Setter Property="Foreground" Value="#DCE4F0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                        <Setter Property="Text" Value="Остановить" />
                                                        <Setter Property="Foreground" Value="#00D68F" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <StackPanel HorizontalAlignment="Center" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#CC3030" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Fill" Value="#00D68F" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontFamily="Segoe UI" FontSize="13" FontWeight="Medium">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Защита не активна" />
                                <Setter Property="Foreground" Value="#8B949E" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Text" Value="Защита активна" />
                                        <Setter Property="Foreground" Value="#00D68F" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Нижняя строка: только аптайм и PID -->
        <Border Grid.Row="1" Background="#0E1120" BorderBrush="#1A1E30"
                BorderThickness="1" CornerRadius="12" Padding="18,10"
                HorizontalAlignment="Center" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="#8B949E" FontSize="11">
                    <Run Text="Аптайм: " />
                    <Run Text="{Binding UptimeText}" Foreground="#DCE4F0" FontWeight="SemiBold" />
                </TextBlock>
                <Rectangle Width="1" Fill="#30363D" Margin="16,0" />
                <TextBlock Foreground="#8B949E" FontSize="11">
                    <Run Text="PID: " />
                    <Run Text="{Binding PidText}" Foreground="#DCE4F0" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
