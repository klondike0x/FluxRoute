<UserControl x:Class="FluxRoute.Views.Tabs.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="460" d:DesignWidth="760">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,12">
            <!-- ═══ ИНФОРМАЦИЯ О ПРИЛОЖЕНИИ ═══ -->
            <Border Background="#0D1117" BorderBrush="#21262D" BorderThickness="1"
                    CornerRadius="8" Padding="14" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Версия сборки:" FontFamily="Segoe UI"
                               Foreground="#8B949E" FontSize="12" Margin="0,0,12,4" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AppVersion}" FontFamily="Consolas"
                               Foreground="#C9D1D9" FontSize="12" Margin="0,0,0,4" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата сборки:" FontFamily="Segoe UI"
                               Foreground="#8B949E" FontSize="12" Margin="0,0,12,4" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AppBuildDate}" FontFamily="Consolas"
                               Foreground="#C9D1D9" FontSize="12" Margin="0,0,0,4" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Репозиторий:" FontFamily="Segoe UI"
                               Foreground="#8B949E" FontSize="12" Margin="0,0,12,4" />
                    <TextBlock Grid.Row="2" Grid.Column="1" FontFamily="Consolas" FontSize="12" Margin="0,0,0,4">
                        <Hyperlink NavigateUri="{Binding AppRepositoryUrl}"
                                   RequestNavigate="Hyperlink_RequestNavigate" Foreground="#58A6FF"
                                   FontFamily="Consolas">github.com/klondike0x/FluxRoute</Hyperlink>
                    </TextBlock>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Лицензия:" FontFamily="Segoe UI"
                               Foreground="#8B949E" FontSize="12" Margin="0,0,12,4" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding AppLicense}" FontFamily="Segoe UI"
                               Foreground="#C9D1D9" FontSize="12" Margin="0,0,0,4" />
                    <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" FontFamily="Segoe UI"
                               Foreground="#4A5170" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                               Text="FluxRoute — свободное программное обеспечение. Вы можете распространять и/или модифицировать его в соответствии с условиями GNU GPLv3." />
                </Grid>
            </Border>

            <TextBlock Style="{StaticResource SecH}" Text="ДЛЯ ЧЕГО СОЗДАН ПРОЕКТ" Margin="0,0,0,8" />
            <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" TextWrapping="Wrap" FontSize="12"
                Text="FluxRoute создан как удобный desktop-интерфейс для управления сетевыми стратегиями и сценариями обхода ограничений. Главная цель — упростить запуск и переключение стратегий без ручного редактирования bat-файлов." />
            <Rectangle Style="{StaticResource Sep}" />
            <TextBlock Style="{StaticResource SecH}" Text="КАК РАБОТАЕТ" />
            <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" TextWrapping="Wrap" FontSize="12"
                Text="Приложение загружает стратегии из каталога engine, запускает выбранный сценарий, отслеживает статус процесса и диагностику. Оркестратор анализирует доступность целей и переключает стратегию на более стабильный." />
            <Rectangle Style="{StaticResource Sep}" />
            <TextBlock Style="{StaticResource SecH}" Text="ОСНОВА ENGINE" />
            <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3"
                Text="FluxRoute использует экосистему проектов:" />
            <StackPanel Margin="8,8,0,0">
                <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3">
                    <Run Text="• " />
                    <Hyperlink NavigateUri="https://github.com/basil00/WinDivert"
                        RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4A90E2">WinDivert</Hyperlink>
                    <Run Text=" — низкоуровневая основа" />
                </TextBlock>
                <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3">
                    <Run Text="• " />
                    <Hyperlink NavigateUri="https://github.com/bol-van/zapret"
                        RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4A90E2">bol-van/zapret</Hyperlink>
                    <Run Text=" — оригинальный проект" />
                </TextBlock>
                <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3">
                    <Run Text="• " />
                    <Hyperlink NavigateUri="https://github.com/Flowseal/zapret-discord-youtube"
                        RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4A90E2">Flowseal/zapret-discord-youtube</Hyperlink>
                    <Run Text=" — основа engine" />
                </TextBlock>
                <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3">
                    <Run Text="• " />
                    <Hyperlink NavigateUri="https://github.com/Flowseal/tg-ws-proxy"
                        RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4A90E2">Flowseal/tg-ws-proxy</Hyperlink>
                    <Run Text=" — Telegram WebSocket прокси" />
                </TextBlock>
            </StackPanel>
            <Rectangle Style="{StaticResource Sep}" />
            <!-- После секции "ОСНОВА ENGINE" -->
            <TextBlock Style="{StaticResource SecH}" Text="ACKNOWLEDGMENTS" />
            <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3"
           Text="FluxRoute был вдохновлён и частично основан на UX-решениях следующих проектов:" />

            <StackPanel Margin="8,8,0,0">
                <!-- Zapret Hub — главная благодарность -->
                <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" 
            CornerRadius="6" Padding="12" Margin="0,4,0,8">
                    <StackPanel>
                        <TextBlock FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#C9D1D9">
                <Hyperlink NavigateUri="https://github.com/goshkow/Zapret-Hub" 
                           RequestNavigate="Hyperlink_RequestNavigate" 
                           Foreground="#58A6FF">Zapret Hub</Hyperlink>
                <Run Text=" by goshkow" />
                        </TextBlock>
                        <TextBlock FontFamily="Segoe UI" Foreground="#8B949E" FontSize="11" 
                       TextWrapping="Wrap" Margin="0,4,0,0"
                       Text="Часть интерфейсных и продуктовых решений была вдохновлена Zapret Hub:" />
                        <TextBlock FontFamily="Segoe UI" Foreground="#8B949E" FontSize="11" 
                       Margin="8,2,0,0" Text="• Auto-Tune (подбор IPSet × GameFilter)" />
                        <TextBlock FontFamily="Segoe UI" Foreground="#8B949E" FontSize="11" 
                       Margin="8,2,0,0" Text="• Интеграция TG WS Proxy в единый интерфейс" />
                        <TextBlock FontFamily="Segoe UI" Foreground="#8B949E" FontSize="11" 
                       Margin="8,2,0,0" Text="• Структура навигации и продуктовый подход" />
                    </StackPanel>
                </Border>

                <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3">
        <Run Text="• " />
        <Hyperlink NavigateUri="https://github.com/medvedeff-true/Zapret-GUI" 
                   RequestNavigate="Hyperlink_RequestNavigate" 
                   Foreground="#4A90E2">Zapret-GUI</Hyperlink>
        <Run Text=" by medvedeff-true" />
                </TextBlock>
                <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3">
        <Run Text="• " />
        <Hyperlink NavigateUri="https://github.com/Virenbar/ZapretControl" 
                   RequestNavigate="Hyperlink_RequestNavigate" 
                   Foreground="#4A90E2">ZapretControl</Hyperlink>
        <Run Text=" by Virenbar" />
                </TextBlock>
                <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3">
        <Run Text="• " />
        <Hyperlink NavigateUri="https://github.com/youtubediscord/zapret" 
                   RequestNavigate="Hyperlink_RequestNavigate" 
                   Foreground="#4A90E2">zapret</Hyperlink>
        <Run Text=" by youtubediscord" />
                </TextBlock>
            </StackPanel>
            <Rectangle Style="{StaticResource Sep}" />
            <TextBlock Style="{StaticResource SecH}" Text="ПОЛЕЗНЫЕ ССЫЛКИ" />
            <StackPanel Margin="8,0,0,0">
                <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3">
                    <Run Text="• " />
                    <Hyperlink NavigateUri="https://github.com/klondike0x/FluxRoute"
                        RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4A90E2">FluxRoute на GitHub</Hyperlink>
                    <Run Text=" — репозиторий проекта" />
                </TextBlock>
                <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3">
                    <Run Text="• " />
                    <Hyperlink NavigateUri="https://github.com/klondike0x/FluxRoute/releases"
                        RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4A90E2">Релизы</Hyperlink>
                    <Run Text=" — скачать последнюю версию" />
                </TextBlock>
                <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3">
                    <Run Text="• " />
                    <Hyperlink NavigateUri="https://github.com/klondike0x/FluxRoute/issues"
                        RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4A90E2">Issues</Hyperlink>
                    <Run Text=" — баг-репорты и предложения" />
                </TextBlock>
                <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3">
                    <Run Text="• " />
                    <Hyperlink NavigateUri="https://github.com/klondike0x"
                        RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4A90E2">klondike0x</Hyperlink>
                    <Run Text=" — страница автора на GitHub" />
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
