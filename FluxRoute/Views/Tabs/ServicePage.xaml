<UserControl x:Class="FluxRoute.Views.Tabs.ServicePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="460" d:DesignWidth="760">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,12">
                <!-- ── БЫСТРЫЕ ПРЕСЕТЫ ── -->
                <TextBlock Style="{StaticResource SecH}" Text="БЫСТРЫЕ ПРЕСЕТЫ" Margin="0,0,0,4" />
                <TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#8B949E"
                           TextWrapping="Wrap" Margin="0,0,0,8"
                           Text="Сохраните текущую конфигурацию (Стратегия + GameFilter + IPSet) как пресет. Укажите имя процесса (.exe) для автопереключения при запуске игры — работает когда оркестратор включён." />
                <ItemsControl ItemsSource="{Binding Presets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#111520" BorderBrush="#21262D" BorderThickness="1"
                                    CornerRadius="4" Padding="10,7" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock FontFamily="Segoe UI" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#C9D1D9"
                                                   Text="{Binding Name}" />
                                        <TextBlock FontFamily="Segoe UI" FontSize="11"
                                                   Foreground="#8B949E" Margin="0,2,0,0">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}Стратегия: {0}  |  GameFilter: {1} ({2})  |  IPSet: {3}">
                                                    <Binding Path="ProfileFileName" FallbackValue="—" />
                                                    <Binding Path="GameFilterEnabled" />
                                                    <Binding Path="GameFilterProtocol" />
                                                    <Binding Path="IpSetMode" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock FontFamily="Segoe UI" FontSize="11"
                                                   Foreground="#58A6FF" Margin="0,1,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TriggerProcess}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="🎮 Триггер: " />
                                            <Run Text="{Binding TriggerProcess}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="▶ Применить"
                                            Style="{StaticResource ActionBtn}"
                                            Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="8,0,6,0" Padding="10,4" />
                                    <Button Grid.Column="2" Content="🗑"
                                            Style="{StaticResource RedBtn}" Width="30" Height="30"
                                            Padding="0" FontSize="12"
                                            Command="{Binding DataContext.RemovePresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Background="#0D1117" BorderBrush="#21262D" BorderThickness="1"
                        CornerRadius="4" Padding="10,8" Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#8B949E"
                                   Text="Сохранить текущую конфигурацию как пресет:" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource Lbl}" Text="Название:"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding NewPresetName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="28" VerticalContentAlignment="Center" Padding="6,0"
                                     Background="#0D1117" Foreground="#C9D1D9" CaretBrush="#C9D1D9"
                                     BorderBrush="#30363D" BorderThickness="1" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource Lbl}"
                                       Text="Триггер (.exe):" VerticalAlignment="Center"
                                       ToolTip="Имя процесса для автопереключения, например: rocketleague.exe" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding NewPresetTrigger, UpdateSourceTrigger=PropertyChanged}"
                                     Height="28" VerticalContentAlignment="Center" Padding="6,0"
                                     Background="#0D1117" Foreground="#C9D1D9" CaretBrush="#C9D1D9"
                                     BorderBrush="#30363D" BorderThickness="1"
                                     ToolTip="Необязательно. Пример: rocketleague.exe" />
                            <Grid Grid.Column="2" Margin="6,0,0,0">
                                <Button Height="28" Padding="10,0"
                                        Style="{StaticResource ActionBtn}"
                                        ToolTip="Выбрать из запущенных процессов"
                                        Command="{Binding OpenProcessPickerCommand}"
                                        Content="📋 Выбрать" />
                                <Popup IsOpen="{Binding ProcessPickerOpen, Mode=TwoWay}"
                                       StaysOpen="False" Placement="Bottom"
                                       AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Background="#161B22" BorderBrush="#30363D"
                                            BorderThickness="1" CornerRadius="4" Padding="4">
                                        <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding RunningProcesses}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding}"
                                                                HorizontalContentAlignment="Left"
                                                                Background="Transparent" BorderThickness="0"
                                                                Foreground="#C9D1D9" FontFamily="Consolas"
                                                                FontSize="12" Padding="8,4" Cursor="Hand"
                                                                Command="{Binding DataContext.PickProcessCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="bd"
                                                                                        Background="{TemplateBinding Background}"
                                                                                        CornerRadius="3"
                                                                                        Padding="{TemplateBinding Padding}">
                                                                                    <ContentPresenter />
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="bd" Property="Background" Value="#21262D" />
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Grid>
                        <Button Content="💾 Сохранить текущую конфигурацию"
                                Style="{StaticResource ActionBtnGreen}"
                                Command="{Binding SavePresetFromCurrentCommand}"
                                HorizontalAlignment="Left" Padding="12,6" />
                    </StackPanel>
                </Border>

                <Rectangle Style="{StaticResource Sep}" Margin="0,12,0,8" />

                <!-- ═══ v1.6.0: ДЕФОЛТНЫЙ ПРОФИЛЬ ДЛЯ ТРИГГЕРОВ ═══ -->
                <TextBlock Style="{StaticResource SecH}" Text="ДЕФОЛТНЫЙ ПРОФИЛЬ" Margin="0,0,0,4" />
                <TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#8B949E"
                           TextWrapping="Wrap" Margin="0,0,0,8"
                           Text="Выберите профиль, на который приложение будет возвращаться после завершения триггерного процесса. Если не выбран — вернётся на профиль, активный перед триггером." />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Lbl}" Text="Профиль:"
                               VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1" Height="28"
                              ItemsSource="{Binding Profiles}"
                              SelectedValuePath="FileName"
                              SelectedValue="{Binding DefaultProfileFileName, UpdateSourceTrigger=PropertyChanged}"
                              Background="#0D1117" Foreground="#C9D1D9"
                              BorderBrush="#30363D" BorderThickness="1"
                              ToolTip="Профиль по умолчанию для возврата из триггера">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" Foreground="#C9D1D9" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="2" Content="✖"
                            Style="{StaticResource RedBtn}" Width="28" Height="28"
                            Padding="0" FontSize="14" Margin="6,0,0,0"
                            Command="{Binding ClearDefaultProfileCommand}"
                            ToolTip="Очистить дефолтный профиль" />
                </Grid>
                <!-- ═══════════════════════════════════════════════════ -->

                <Rectangle Style="{StaticResource Sep}" Margin="0,12,0,8" />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource SecH}" Text="ПОДОБРАТЬ НАСТРОЙКИ" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="?" Width="22" Height="22" Padding="0" FontSize="11" FontWeight="Bold"
                            Foreground="#58A6FF" Background="Transparent" BorderBrush="#58A6FF" BorderThickness="1"
                            Cursor="Hand" Margin="8,0,0,0"
                            Command="{Binding Service.OpenAutoTuneHelpCommand}"
                            ToolTip="Что такое Auto-Tune?" />
                </Grid>
                <TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#8B949E"
                           TextWrapping="Wrap" Margin="0,0,0,8"
                           Text="Приложение автоматически проверит все комбинации IPSet и GameFilter и предложит лучшую для текущей стратегии." />
                <Button Content="🔍 Подобрать настройки" Style="{StaticResource ActionBtnAccent}"
                        Command="{Binding Service.StartAutoTuneCommand}"
                        HorizontalAlignment="Left" Padding="12,6" Margin="0,0,0,4"
                        ToolTip="Автоматически перебирает комбинации IPSet и GameFilter для вашей сети. Результат — оптимальная настройка за 1–2 минуты." />

                <Rectangle Style="{StaticResource Sep}" Margin="0,12,0,8" />

                <!-- ── GAME FILTER ── -->
                <TextBlock Style="{StaticResource SecH}" Text="GAME FILTER" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Style="{StaticResource Lbl}" Text="Статус: " Margin="0,0,4,0" />
                    <TextBlock FontFamily="Segoe UI" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Выключен" />
                                <Setter Property="Foreground" Value="#E74C3C" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GameFilterEnabled}" Value="True">
                                        <Setter Property="Text" Value="Включён" />
                                        <Setter Property="Foreground" Value="#00D68F" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <TextBlock FontFamily="Segoe UI" Foreground="#2E3550" FontSize="11"
                           Margin="0,2,0,8" TextWrapping="Wrap"
                           Text="Расширяет диапазон портов (1024-65535) для обхода в играх." />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Command="{Binding ToggleGameFilterCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                                <Setter Property="Content" Value="Включить" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GameFilterEnabled}" Value="True">
                                        <Setter Property="Content" Value="Выключить" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <ComboBox ItemsSource="{Binding GameFilterProtocols}"
                              SelectedItem="{Binding GameFilterProtocol}"
                              Width="120" Margin="10,0,0,0" />
                </StackPanel>
                <Rectangle Style="{StaticResource Sep}" />

                <!-- ── IPSET FILTER ── -->
                <TextBlock Style="{StaticResource SecH}" Text="IPSET FILTER" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Style="{StaticResource Lbl}" Text="Режим: " Margin="0,0,4,0" />
                    <TextBlock Style="{StaticResource Val}" Text="{Binding IpSetMode}" />
                </StackPanel>
                <TextBlock FontFamily="Segoe UI" Foreground="#2E3550" FontSize="11"
                           Margin="0,2,0,8" TextWrapping="Wrap"
                           Text="loaded — фильтрация по списку IP · none — отключена · any — все адреса" />
                <StackPanel Orientation="Horizontal">
                    <Button Content="Переключить режим" Style="{StaticResource ActionBtn}"
                            Margin="0,0,10,0" Command="{Binding CycleIpSetModeCommand}" />
                    <Button Command="{Binding UpdateIpSetListCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionBtnAccent}">
                                <Setter Property="Content" Value="Обновить IPSet" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsServiceBusy}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                <Rectangle Style="{StaticResource Sep}" />

                <!-- ── HOSTS FILE ── -->
                <TextBlock Style="{StaticResource SecH}" Text="HOSTS FILE" />
                <TextBlock FontFamily="Segoe UI" Foreground="#2E3550" FontSize="11"
                           Margin="0,0,0,8" TextWrapping="Wrap"
                           Text="Проверяет и обновляет системный hosts файл." />
                <Button Content="Проверить / обновить Hosts" HorizontalAlignment="Left"
                        Command="{Binding UpdateHostsFileCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsServiceBusy}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Rectangle Style="{StaticResource Sep}" />

                <!-- ── СЛУЖБА ZAPRET ── -->
                <TextBlock Style="{StaticResource SecH}" Text="СЛУЖБА ZAPRET" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Style="{StaticResource Lbl}" Text="Статус: " Margin="0,0,4,0" />
                    <TextBlock Style="{StaticResource Val}" Text="{Binding ZapretServiceStatus}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Установить" Style="{StaticResource ActionBtnGreen}"
                            Margin="0,0,10,0" Command="{Binding InstallZapretServiceCommand}" />
                    <Button Content="Остановить" Style="{StaticResource ActionBtnRed}"
                            Margin="0,0,10,0" Command="{Binding ForceStopZapretServiceCommand}" />
                    <Button Content="↻" Style="{StaticResource ActionBtn}"
                            Command="{Binding RefreshServiceInfoCommand}" />
                </StackPanel>
                <Border Background="#1C1800" BorderBrush="#4A3800" BorderThickness="1"
                        CornerRadius="8" Padding="10,8" Margin="0,12,0,0">
                    <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="11"
                               Foreground="#F0B429"
                               Text="Установка службы запускает service.bat с правами администратора." />
                </Border>

                <Border Style="{StaticResource LogArea}" x:Name="ServiceLogContainer" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="ServiceLogScroll">
                        <ItemsControl ItemsSource="{Binding ServiceLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#4A5170"
                                               FontFamily="Segoe UI" FontSize="11" Margin="0,2" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>