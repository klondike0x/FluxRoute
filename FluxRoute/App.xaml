<Application x:Class="FluxRoute.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FluxRoute"
             xmlns:conv="clr-namespace:FluxRoute.Converters"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/ScrollBarStyle.xaml"/>
                <ResourceDictionary Source="Styles/Colors.xaml"/>
                <ResourceDictionary Source="Styles/CommonStyles.xaml"/>
                <ResourceDictionary Source="Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="Styles/InputStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Глобальные конвертеры, доступные во всех UserControl и Window -->
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <conv:InverseBooleanConverter x:Key="InvBool" />
            <conv:BoolToInstalledConverter x:Key="BoolToInstalled" />
            <conv:NavIndicatorYConverter x:Key="NavIndicatorY" />
        </ResourceDictionary>
    </Application.Resources>
</Application>