```gitignore
# Build artifacts
*.dll
*.exe
*.pdb
*.so
*.dylib
*.obj
*.o
*.a
*.lib
*.out

# Dependencies
packages/
node_modules/
vendor/

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# IDE specific
.vs/
.idea/
*.userprefs
*.user
*.suo
*.userosscache
*.sln.docstates

# Configuration
appsettings.Production.json
appsettings.Development.json
```
